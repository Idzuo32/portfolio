              >
              <span
                class="badge skill-badge text-xs bg-[#1F1F1F] text-[#888888] px-2 py-1 rounded"
                >Meshy AI</span
              >
              <span
                class="badge skill-badge text-xs bg-[#1F1F1F] text-[#888888] px-2 py-1 rounded"
                >Flowith AI</span
              >
            </div>
          </div>
        </div>

        <!-- Additional skill pills -->
        <div class="reveal flex flex-wrap gap-2.5" style="--delay: 150ms">
          {
            [
              "AI State Machines",
              "Procedural Generation",
              "Object Pooling",
              "Event-Driven Architecture",
              "Game Systems Design",
              "Editor Tooling",
              "Git / GitHub",
