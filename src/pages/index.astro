              >
            </div>
          </div>

          <!-- C# -->
          <div
            class="skill-card reveal bg-[#141414] border border-[#1F1F1F] rounded-xl p-6 hover:border-green-800/60 transition-colors duration-150"
            style="--card-accent: rgb(74,222,128); --card-accent-dim: rgba(74,222,128,0.18); --delay: 300ms"
