        <!-- Desktop nav -->
        <ul class="hidden sm:flex gap-6 text-sm text-[#888888]">
          <li>
            <a
              href="#skills"
              class="nav-link hover:text-[#F0F0F0] transition-colors duration-150"
              >Skills</a
            >
          </li>
          <li>
            <a
              href="#projects"
              class="nav-link hover:text-[#F0F0F0] transition-colors duration-150"
              >Projects</a
            >
          </li>
          <li>
            <a
              href="#contact"
              class="nav-link hover:text-[#F0F0F0] transition-colors duration-150"
