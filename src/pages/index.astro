          >
            <div
              class="w-11 h-11 bg-[#1F1F1F] rounded-lg flex items-center justify-center mb-5"
            >
              <span class="font-bold text-cyan-400 font-mono text-base">G4</span
              >
            </div>
            <h3 class="font-semibold text-[#F0F0F0] mb-1">Godot</h3>
            <p class="text-[#888888] text-xs mb-4">GDScript · 2D & 3D</p>
            <div class="flex flex-wrap gap-1.5">
              <span
                class="badge skill-badge text-xs bg-[#1F1F1F] text-[#888888] px-2 py-1 rounded"
                >GDScript</span
              >
              <span
                class="badge skill-badge text-xs bg-[#1F1F1F] text-[#888888] px-2 py-1 rounded"
                >2D</span
              >
              <span
                class="badge skill-badge text-xs bg-[#1F1F1F] text-[#888888] px-2 py-1 rounded"
