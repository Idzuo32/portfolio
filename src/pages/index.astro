---
import "../styles/global.css";
import { getCollection } from 'astro:content';
import BlogCard from '../components/BlogCard.astro';

const recentPosts = (await getCollection('blog'))
  .filter(p => !p.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 2)
  .map(post => {
    const words = (post.body ?? '').split(/\s+/).filter(Boolean).length;
    return { ...post, readingTime: Math.max(1, Math.ceil(words / 200)) };
  });
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="Marko Stankovic — Game Developer. Unity 3D, Unreal Engine, Godot. Building AI systems, procedural generation, and editor tooling. Based in Serbia, open to remote."
    />
    <link
      rel="icon"
      type="image/svg+xml"
      href={`${import.meta.env.BASE_URL}favicon.svg`}
    />
    <title>Marko Stankovic — Game Developer</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Geist:wght@300;400;500;600;700&family=JetBrains+Mono:ital,wght@0,400;0,500;0,600;0,700&display=swap"
      rel="stylesheet"
    />
    <style>
      /* ── Thumbnail hover scale ── */
      .thumb-wrap {
        overflow: hidden;
      }
      .thumb-wrap video,
      .thumb-wrap img {
        transition: transform 0.3s ease;
        will-change: transform;
      }
      .project-card:hover .thumb-wrap video,
      .project-card:hover .thumb-wrap img {
        transform: scale(1.03);
      }

      /* ── Lightbox ── */
      #lightbox {
        display: none;
        opacity: 0;
        transition: opacity 0.2s ease;
      }
      #lightbox.lb-open {
        display: flex;
        opacity: 1;
      }
      #lightbox-content {
        transform: scale(0.95);
        transition: transform 0.2s ease;
      }
      #lightbox.lb-open #lightbox-content {
        transform: scale(1);
      }
      #lightbox-img {
        max-width: 90vw;
        max-height: 90vh;
        object-fit: contain;
        border-radius: 0.5rem;
        display: block;
      }
      .lb-btn {
        width: 2.75rem;
        height: 2.75rem;
        border-radius: 9999px;
        background: rgba(31, 31, 31, 0.8);
        border: 1px solid #2a2a2a;
        color: #f0f0f0;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        flex-shrink: 0;
        transition: background 0.15s ease, border-color 0.15s ease;
      }
      .lb-btn:hover {
        background: rgba(50, 50, 50, 0.9);
        border-color: #888;
      }
      .lb-btn:disabled {
        opacity: 0.3;
        cursor: default;
      }
      #lightbox-close {
        position: absolute;
        top: 1rem;
        right: 1rem;
      }
    </style>
  </head>

  <body class="font-sans antialiased">
    <!-- ─── NAV ──────────────────────────────────────────────────────────── -->
    <header
      class="fixed top-0 inset-x-0 z-50 border-b border-[#1F1F1F]/60 bg-[#0D0D0D]/80 backdrop-blur-md"
