                >Omarchy setup & configuration</span
              >
            </div>
          </div>

          <!-- AI Tools -->
          <div
            class="skill-card reveal bg-[#141414] border border-[#1F1F1F] rounded-xl p-6 hover:border-purple-800/60 transition-colors duration-150"
