---
import "../styles/global.css";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="Marko Stankovic — Game Developer. Unity 3D, Unreal Engine, Godot. Building AI systems, procedural generation, and editor tooling. Based in Serbia, open to remote."
    />
    <link
      rel="icon"
      type="image/svg+xml"
      href={`${import.meta.env.BASE_URL}favicon.svg`}
    />
    <title>Marko Stankovic — Game Developer</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Geist:wght@300;400;500;600;700&family=JetBrains+Mono:ital,wght@0,400;0,500;0,600;0,700&display=swap"
      rel="stylesheet"
    />
  </head>

  <body class="font-sans antialiased">
    <!-- ─── NAV ──────────────────────────────────────────────────────────── -->
    <header
      class="fixed top-0 inset-x-0 z-50 border-b border-[#1F1F1F]/60 bg-[#0D0D0D]/80 backdrop-blur-md"
    >
      <nav
        class="max-w-5xl mx-auto px-6 h-14 flex items-center justify-between"
      >
        <a href="#hero" class="font-bold font-mono tracking-tight text-[#F0F0F0] text-lg"
          >MS</a
        >
        <ul class="flex gap-6 text-sm text-[#888888]">
          <li>
            <a
              href="#skills"
              class="hover:text-[#F0F0F0] transition-colors duration-150">Skills</a
            >
          </li>
          <li>
            <a
              href="#projects"
              class="hover:text-[#F0F0F0] transition-colors duration-150"
              >Projects</a
            >
          </li>
          <li>
            <a
              href="#contact"
              class="hover:text-[#F0F0F0] transition-colors duration-150">Contact</a
            >
          </li>
        </ul>
      </nav>
    </header>

    <!-- ─── HERO ──────────────────────────────────────────────────────────── -->
    <section id="hero" class="relative min-h-screen flex items-center pt-14">
      <!-- Decorative background glows -->
      <div
        class="absolute inset-0 overflow-hidden pointer-events-none"
        aria-hidden="true"
      >
        <div
          class="absolute top-1/4 left-1/3 w-[700px] h-[700px] bg-[#00FFC8]/5 rounded-full blur-3xl"
        >
        </div>
        <div
          class="absolute bottom-1/4 right-1/4 w-[400px] h-[400px] bg-[#00FFC8]/3 rounded-full blur-3xl"
        >
        </div>
      </div>

      <div class="relative max-w-5xl mx-auto px-6 py-28">
        <p class="text-[#00FFC8] font-mono text-sm mb-5 tracking-wide">
          Hello, I'm
        </p>

        <h1
          class="hero-name font-bold text-[#F0F0F0] mb-5"
        >
          Marko Stankovic
        </h1>

        <p class="text-2xl sm:text-3xl text-[#888888] font-light mb-8 cursor-blink">
          Game Developer
        </p>

        <p class="text-[#888888] text-lg max-w-xl mb-12 leading-relaxed">
          Building games with Unity&nbsp;3D, Unreal Engine, and Godot. 3+ years
          shipping systems — AI state machines, procedural generation, and
          editor tooling. Based in Serbia, open to remote.
        </p>

        <div class="flex flex-wrap gap-4">
          <a
            href="#contact"
            class="px-6 py-3 bg-[#00FFC8] hover:bg-[#00FFD0] text-[#0D0D0D] rounded-lg font-medium transition-colors duration-150"
          >
            Get in Touch
          </a>
          <a
            href="#projects"
            class="px-6 py-3 border border-[#1F1F1F] hover:border-[#888888] text-[#888888] hover:text-[#F0F0F0] rounded-lg font-medium transition-colors duration-150"
          >
            View Projects
          </a>
        </div>
      </div>
    </section>

    <!-- ─── SKILLS ────────────────────────────────────────────────────────── -->
    <section id="skills" class="py-24 border-t border-[#1F1F1F]/50">
      <div class="max-w-5xl mx-auto px-6">
        <h2 class="text-3xl font-bold text-[#F0F0F0] mb-2">Skills</h2>
        <p class="text-[#888888] mb-12">The tools I think in and build with.</p>

        <!-- Primary engine cards -->
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
          <!-- Unity 3D -->
          <div
            class="bg-[#141414] border border-[#1F1F1F] rounded-xl p-6 hover:border-violet-800/60 transition-colors duration-150"
          >
            <div
              class="w-11 h-11 bg-[#1F1F1F] rounded-lg flex items-center justify-center mb-5"
            >
              <span class="font-bold text-violet-400 font-mono text-base"
                >U3D</span
              >
            </div>
            <h3 class="font-semibold text-[#F0F0F0] mb-1">Unity 3D</h3>
            <p class="text-[#888888] text-xs mb-4">3+ years</p>
            <div class="flex flex-wrap gap-1.5">
              <span
                class="text-xs bg-[#1F1F1F] text-[#888888] px-2 py-1 rounded"
                >C#</span
              >
              <span
                class="text-xs bg-[#1F1F1F] text-[#888888] px-2 py-1 rounded"
                >Strategy</span
              >
              <span
                class="text-xs bg-[#1F1F1F] text-[#888888] px-2 py-1 rounded"
                >Event-Driven</span
              >
              <span
                class="text-xs bg-[#1F1F1F] text-[#888888] px-2 py-1 rounded"
                >Object Pooling</span
              >
            </div>
          </div>

          <!-- Unreal Engine -->
          <div
            class="bg-[#141414] border border-[#1F1F1F] rounded-xl p-6 hover:border-blue-800/60 transition-colors duration-150"
          >
            <div
              class="w-11 h-11 bg-[#1F1F1F] rounded-lg flex items-center justify-center mb-5"
            >
              <span class="font-bold text-blue-400 font-mono text-base">UE</span
              >
            </div>
            <h3 class="font-semibold text-[#F0F0F0] mb-1">Unreal Engine</h3>
            <p class="text-[#888888] text-xs mb-4">Blueprints + C++</p>
            <div class="flex flex-wrap gap-1.5">
              <span
                class="text-xs bg-[#1F1F1F] text-[#888888] px-2 py-1 rounded"
                >Blueprints</span
              >
              <span
                class="text-xs bg-[#1F1F1F] text-[#888888] px-2 py-1 rounded"
                >C++</span
              >
              <span
                class="text-xs bg-[#1F1F1F] text-[#888888] px-2 py-1 rounded"
                >Gameplay</span
              >
            </div>
          </div>

          <!-- Godot -->
          <div
            class="bg-[#141414] border border-[#1F1F1F] rounded-xl p-6 hover:border-cyan-800/60 transition-colors duration-150"
          >
            <div
              class="w-11 h-11 bg-[#1F1F1F] rounded-lg flex items-center justify-center mb-5"
            >
              <span class="font-bold text-cyan-400 font-mono text-base">G4</span
              >
            </div>
            <h3 class="font-semibold text-[#F0F0F0] mb-1">Godot</h3>
            <p class="text-[#888888] text-xs mb-4">GDScript · 2D & 3D</p>
            <div class="flex flex-wrap gap-1.5">
              <span
                class="text-xs bg-[#1F1F1F] text-[#888888] px-2 py-1 rounded"
                >GDScript</span
              >
              <span
                class="text-xs bg-[#1F1F1F] text-[#888888] px-2 py-1 rounded"
                >2D</span
              >
              <span
                class="text-xs bg-[#1F1F1F] text-[#888888] px-2 py-1 rounded"
                >3D</span
              >
            </div>
          </div>

          <!-- C# -->
          <div
            class="bg-[#141414] border border-[#1F1F1F] rounded-xl p-6 hover:border-green-800/60 transition-colors duration-150"
          >
            <div
              class="w-11 h-11 bg-[#1F1F1F] rounded-lg flex items-center justify-center mb-5"
            >
              <span class="font-bold text-green-400 font-mono text-base"
                >C#</span
              >
            </div>
            <h3 class="font-semibold text-[#F0F0F0] mb-1">C#</h3>
            <p class="text-[#888888] text-xs mb-4">Primary language</p>
            <div class="flex flex-wrap gap-1.5">
              <span
                class="text-xs bg-[#1F1F1F] text-[#888888] px-2 py-1 rounded"
                >OOP</span
              >
              <span
                class="text-xs bg-[#1F1F1F] text-[#888888] px-2 py-1 rounded"
                >Interfaces</span
              >
              <span
                class="text-xs bg-[#1F1F1F] text-[#888888] px-2 py-1 rounded"
                >Events</span
              >
              <span
                class="text-xs bg-[#1F1F1F] text-[#888888] px-2 py-1 rounded"
                >Patterns</span
              >
            </div>
          </div>
        </div>

        <!-- Arch Linux + AI Tools -->
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-8">
          <!-- Arch Linux -->
          <div
            class="bg-[#141414] border border-[#1F1F1F] rounded-xl p-6 hover:border-sky-800/60 transition-colors duration-150"
          >
            <div
              class="w-11 h-11 bg-[#1F1F1F] rounded-lg flex items-center justify-center mb-5"
            >
              <span class="font-bold text-sky-400 font-mono text-base">>_</span>
            </div>
            <h3 class="font-semibold text-[#F0F0F0] mb-1">Arch Linux</h3>
            <p class="text-[#888888] text-xs mb-4">Daily driver</p>
            <div class="flex flex-wrap gap-1.5">
              <span
                class="text-xs bg-[#1F1F1F] text-[#888888] px-2 py-1 rounded"
                >Bash scripting</span
              >
              <span
                class="text-xs bg-[#1F1F1F] text-[#888888] px-2 py-1 rounded"
                >Neovim</span
              >
              <span
                class="text-xs bg-[#1F1F1F] text-[#888888] px-2 py-1 rounded"
                >Hyprland</span
              >
              <span
                class="text-xs bg-[#1F1F1F] text-[#888888] px-2 py-1 rounded"
                >Waybar</span
              >
              <span
                class="text-xs bg-[#1F1F1F] text-[#888888] px-2 py-1 rounded"
                >Omarchy setup & configuration</span
              >
            </div>
          </div>

          <!-- AI Tools -->
          <div
            class="bg-[#141414] border border-[#1F1F1F] rounded-xl p-6 hover:border-purple-800/60 transition-colors duration-150"
          >
            <div
              class="w-11 h-11 bg-[#1F1F1F] rounded-lg flex items-center justify-center mb-5"
            >
              <span class="font-bold text-purple-400 font-mono text-base"
                >AI</span
              >
            </div>
            <h3 class="font-semibold text-[#F0F0F0] mb-1">AI Tools</h3>
            <p class="text-[#888888] text-xs mb-4">Coding & design workflow</p>
            <div class="flex flex-wrap gap-1.5">
              <span
                class="text-xs bg-[#1F1F1F] text-[#888888] px-2 py-1 rounded"
                >Claude Code</span
              >
              <span
                class="text-xs bg-[#1F1F1F] text-[#888888] px-2 py-1 rounded"
                >OpenCode</span
              >
              <span
                class="text-xs bg-[#1F1F1F] text-[#888888] px-2 py-1 rounded"
                >Meshy AI</span
              >
              <span
                class="text-xs bg-[#1F1F1F] text-[#888888] px-2 py-1 rounded"
                >Flowith AI</span
              >
            </div>
          </div>
        </div>

        <!-- Additional skill pills -->
        <div class="flex flex-wrap gap-2.5">
          {
            [
              "AI State Machines",
              "Procedural Generation",
              "Object Pooling",
              "Event-Driven Architecture",
              "Game Systems Design",
              "Editor Tooling",
              "Git / GitHub",
              "Version Control",
            ].map((skill) => (
              <span class="text-sm bg-[#141414] border border-[#1F1F1F] text-[#888888] px-3 py-1.5 rounded-lg">
                {skill}
              </span>
            ))
          }
        </div>
      </div>
    </section>

    <!-- ─── PROJECTS ──────────────────────────────────────────────────────── -->
    <section id="projects" class="py-24 border-t border-[#1F1F1F]/50">
      <div class="max-w-5xl mx-auto px-6">
        <h2 class="text-3xl font-bold text-[#F0F0F0] mb-2">Projects</h2>
        <p class="text-[#888888] mb-12">What I've been building.</p>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
          <!-- Hide & Seek -->
          <article
            class="bg-[#141414] border border-[#1F1F1F] rounded-xl p-8 hover:border-violet-800/50 transition-colors duration-150 flex flex-col"
          >
            <header class="flex items-start justify-between mb-5">
              <span
                class="text-xs font-mono bg-[#00FFC8]/10 text-[#00FFC8] border border-[#00FFC8]/20 px-3 py-1 rounded-full"
              >
                In Development
              </span>
              <span class="text-xs text-[#444444] font-mono">Unity 3D</span>
            </header>

            <h3 class="text-xl font-bold text-[#F0F0F0] mb-3">Hide & Seek</h3>

            <p class="text-[#888888] text-sm leading-relaxed mb-5 flex-1">
              Top-down 3D stealth game. Built a full enemy AI using the
              <code
                class="font-mono text-[#00FFC8] text-xs bg-[#00FFC8]/10 px-1 rounded"
                >IEnemyState</code
              >
              interface — five states: Idle, Patrol, Chase, Investigate, Search.
              <code
                class="font-mono text-[#00FFC8] text-xs bg-[#00FFC8]/10 px-1 rounded"
                >NavMeshAgent</code
              >
              drives pathfinding; Cinemachine handles the dynamic camera. Level layout
              built with custom Editor utilities.
            </p>

            <div class="flex flex-wrap gap-2 mb-6">
              {
                [
                  "Data-Driven",
                  "State Machine",
                  "Strategy Pattern",
                  "Hiding System",
                  "Detection System",
                ].map((tag) => (
                  <span class="text-xs bg-[#1F1F1F] text-[#888888] px-2 py-1 rounded">
                    {tag}
                  </span>
                ))
              }
            </div>

            <a
              href="https://github.com/Idzuo32/hide_and_seek_3d"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 text-sm text-[#888888] hover:text-[#00FFC8] transition-colors duration-150"
            >
              View on GitHub
              <svg
                class="w-4 h-4"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                aria-hidden="true"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
              </svg>
            </a>
          </article>

          <!-- Endless Runner -->
          <article
            class="bg-[#141414] border border-[#1F1F1F] rounded-xl p-8 hover:border-cyan-800/50 transition-colors duration-150 flex flex-col"
          >
            <header class="flex items-start justify-between mb-5">
              <span
                class="text-xs font-mono bg-cyan-500/10 text-cyan-400 border border-cyan-500/20 px-3 py-1 rounded-full"
              >
                Completed
              </span>
              <span class="text-xs text-[#444444] font-mono">Unity 3D</span>
            </header>

            <h3 class="text-xl font-bold text-[#F0F0F0] mb-3">Endless Runner</h3>

            <p class="text-[#888888] text-sm leading-relaxed mb-5 flex-1">
              Third-person 3D runner with infinite levels. Chunk-based
              procedural generation spawns terrain, obstacles, and collectibles
              at runtime. Object pooling handles obstacles, VFX, and SFX with
              zero allocations during play. Event-driven architecture keeps all
              systems decoupled. Lane-based movement with Cinemachine camera.
            </p>

            <div class="flex flex-wrap gap-2 mb-6">
              {
                [
                  "Proc Gen",
                  "Object Pooling",
                  "Event-Driven",
                  "Utility Scripts",
                  "Lane Movement",
                  "C#",
                ].map((tag) => (
                  <span class="text-xs bg-[#1F1F1F] text-[#888888] px-2 py-1 rounded">
                    {tag}
                  </span>
                ))
              }
            </div>

            <a
              href="https://github.com/Idzuo32/DiplomskiRad"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 text-sm text-[#888888] hover:text-cyan-300 transition-colors duration-150"
            >
              View on GitHub
              <svg
                class="w-4 h-4"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                aria-hidden="true"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
              </svg>
            </a>
          </article>
        </div>
      </div>
    </section>

    <!-- ─── CONTACT ──────────────────────────────────────────────────────── -->
    <section id="contact" class="py-24 border-t border-[#1F1F1F]/50">
      <div class="max-w-5xl mx-auto px-6">
        <div class="max-w-lg">
          <h2 class="text-3xl font-bold text-[#F0F0F0] mb-2">Get in Touch</h2>
          <p class="text-[#888888] mb-10 leading-relaxed">
            Looking for game dev roles in Serbia and remote. If you have a
            project or a role that fits, let's talk.
          </p>

          <div class="flex flex-col gap-3">
            <!-- Email -->
            <a
              href="mailto:contact@markostankovic.org"
              class="flex items-center gap-4 p-4 bg-[#141414] border border-[#1F1F1F] rounded-xl hover:border-[#888888] transition-colors duration-150 group"
            >
              <div
                class="w-11 h-11 bg-[#1F1F1F] rounded-lg flex items-center justify-center shrink-0"
              >
                <svg
                  class="w-5 h-5 text-[#00FFC8]"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                  aria-hidden="true"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                  ></path>
                </svg>
              </div>
              <div class="min-w-0">
                <p class="text-xs text-[#444444] mb-0.5">Email</p>
                <p
                  class="text-[#F0F0F0] group-hover:text-[#00FFC8] transition-colors duration-150 text-sm truncate"
                >
                  contact@markostankovic.org
                </p>
              </div>
            </a>

            <!-- GitHub -->
            <a
              href="https://github.com/Idzuo32"
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center gap-4 p-4 bg-[#141414] border border-[#1F1F1F] rounded-xl hover:border-[#888888] transition-colors duration-150 group"
            >
              <div
                class="w-11 h-11 bg-[#1F1F1F] rounded-lg flex items-center justify-center shrink-0"
              >
                <svg
                  class="w-5 h-5 text-[#888888]"
                  fill="currentColor"
                  viewBox="0 0 24 24"
                  aria-hidden="true"
                >
                  <path
                    d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"
                  ></path>
                </svg>
              </div>
              <div>
                <p class="text-xs text-[#444444] mb-0.5">GitHub</p>
                <p
                  class="text-[#F0F0F0] group-hover:text-[#888888] transition-colors duration-150 text-sm"
                >
                  github.com/Idzuo32
                </p>
              </div>
            </a>

            <!-- LinkedIn -->
            <a
              href="https://www.linkedin.com/in/markostankovicepicurl/"
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center gap-4 p-4 bg-[#141414] border border-[#1F1F1F] rounded-xl hover:border-[#888888] transition-colors duration-150 group"
            >
              <div
                class="w-11 h-11 bg-[#1F1F1F] rounded-lg flex items-center justify-center shrink-0"
              >
                <svg
                  class="w-5 h-5 text-blue-400"
                  fill="currentColor"
                  viewBox="0 0 24 24"
                  aria-hidden="true"
                >
                  <path
                    d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
                  ></path>
                </svg>
              </div>
              <div>
                <p class="text-xs text-[#444444] mb-0.5">LinkedIn</p>
                <p
                  class="text-[#F0F0F0] group-hover:text-blue-300 transition-colors duration-150 text-sm"
                >
                  Marko Stankovic
                </p>
              </div>
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- ─── FOOTER ────────────────────────────────────────────────────────── -->
