            ].map((skill) => (
              <span class="text-sm bg-[#141414] border border-[#1F1F1F] text-[#888888] px-3 py-1.5 rounded-lg">
                {skill}
              </span>
            ))
          }
        </div>
      </div>
    </section>

    <!-- ─── PROJECTS ──────────────────────────────────────────────────────── -->
    <section id="projects" class="py-24 border-t border-[#1F1F1F]/50">
      <div class="max-w-5xl mx-auto px-6">
        <h2 class="reveal text-3xl font-bold text-[#F0F0F0] mb-2">Projects</h2>
        <p class="reveal text-[#888888] mb-8" style="--delay: 100ms">
          Things built with intent, not just output.
        </p>

        <!-- Filter Bar — JS populates buttons -->
        <div
          id="filter-bar"
          class="reveal flex gap-2 overflow-x-auto pb-1 mb-10"
          role="group"
          aria-label="Filter projects by tag"
          style="--delay: 150ms"
        >
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
          <!-- Hide & Seek -->
          <article
            class="project-card reveal bg-[#141414] border border-[#1F1F1F] rounded-xl overflow-hidden hover:border-violet-800/50 transition-colors duration-150 flex flex-col"
            style="--card-glow: rgba(139,92,246,0.1); --delay: 0ms"
            data-tags="Data-Driven,State Machine,Strategy Pattern,Hiding System,Detection System"
            data-screenshots="/assets/screenshots/hide-and-seek-1.png,/assets/screenshots/hide-and-seek-2.png"
          >
            <!-- 16:9 thumbnail -->
            <div
              class="thumb-wrap w-full aspect-video shrink-0 cursor-pointer relative"
              role="button"
              tabindex="0"
              aria-label="Open Hide &amp; Seek screenshots"
            >
              <video
                class="w-full h-full object-cover"
                autoplay
                loop
                muted
                playsinline
                preload="none"
                poster="/assets/screenshots/hide-and-seek-1.png"
              >
                <source src="/assets/thumbnails/hide-and-seek-thumb.mp4" type="video/mp4" />
              </video>
            </div>

            <!-- Card content -->
            <div class="p-8 flex flex-col flex-1">
              <header class="flex items-start justify-between mb-5">
                <span
                  class="text-xs font-mono bg-[#00FFC8]/10 text-[#00FFC8] border border-[#00FFC8]/20 px-3 py-1 rounded-full"
                >
                  In Development
                </span>
                <span class="text-xs text-[#444444] font-mono">Unity 3D</span>
              </header>

              <h3 class="text-xl font-bold text-[#F0F0F0] mb-3">Hide & Seek</h3>

              <p class="text-[#888888] text-sm leading-relaxed mb-5 flex-1">
                Top-down 3D stealth game. Built a full enemy AI using the
                <code
                  class="font-mono text-[#00FFC8] text-xs bg-[#00FFC8]/10 px-1 rounded"
                  >IEnemyState</code
                >
                interface — five states: Idle, Patrol, Chase, Investigate, Search.
                <code
                  class="font-mono text-[#00FFC8] text-xs bg-[#00FFC8]/10 px-1 rounded"
                  >NavMeshAgent</code
                >
                drives pathfinding; Cinemachine handles the dynamic camera. Level
                layout built with custom Editor utilities.
              </p>

              <div class="flex flex-wrap gap-2 mb-6">
                {
                  [
                    "Data-Driven",
                    "State Machine",
                    "Strategy Pattern",
                    "Hiding System",
                    "Detection System",
                  ].map((tag) => (
                    <span class="project-tag text-xs bg-[#1F1F1F] text-[#888888] px-2 py-1 rounded">
                      {tag}
                    </span>
                  ))
                }
              </div>

              <!-- CTAs -->
              <div class="flex flex-wrap gap-3">
                <a
                  href="https://github.com/Idzuo32/hide_and_seek_3d"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center gap-2 px-4 py-2.5 rounded-lg border border-[#1F1F1F] hover:border-[#888888] text-sm text-[#888888] hover:text-[#F0F0F0] transition-colors duration-150 min-h-[44px]"
