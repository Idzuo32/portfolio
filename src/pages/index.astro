            <h3 class="font-semibold text-[#F0F0F0] mb-1">C#</h3>
            <p class="text-[#888888] text-xs mb-4">Primary language</p>
            <div class="flex flex-wrap gap-1.5">
              <span
                class="badge skill-badge text-xs bg-[#1F1F1F] text-[#888888] px-2 py-1 rounded"
                >OOP</span
              >
              <span
                class="badge skill-badge text-xs bg-[#1F1F1F] text-[#888888] px-2 py-1 rounded"
                >Interfaces</span
              >
              <span
                class="badge skill-badge text-xs bg-[#1F1F1F] text-[#888888] px-2 py-1 rounded"
                >Events</span
              >
              <span
