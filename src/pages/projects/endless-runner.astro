---
import "../../styles/global.css";
const base = import.meta.env.BASE_URL;

const pageTitle = "Endless Runner — Marko Stankovic";
const pageDescription = "Unity 2022 bachelor's thesis — world-scrolling procedural generation, Queue-based object pooling, chunk self-management, and exponentially decaying difficulty escalation.";
const canonicalURL = Astro.url.href;
const ogImageURL = new URL('/og-default.png', Astro.site).href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <link rel="canonical" href={canonicalURL} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content={ogImageURL} />
    <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Geist:wght@300;400;500;600;700&family=JetBrains+Mono:ital,wght@0,400;0,500;0,600;0,700&display=swap"
      rel="stylesheet"
    />

    <!-- highlight.js -->
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.10.0/styles/github-dark.min.css"
    />
    <script src="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.10.0/highlight.min.js"></script>

    <style is:global>
      /* ── Mobile overflow fix ── */
      body {
        overflow-x: hidden;
      }

      /* ── Code blocks ── */
      pre {
        overflow-x: auto;
        max-width: 100%;
        white-space: pre;
      }

      pre code.hljs {
        background: #141414;
        border: 1px solid #1F1F1F;
        border-radius: 0.5rem;
        font-size: 0.8125rem;
        line-height: 1.6;
        padding: 1.25rem 1.5rem;
      }

      /* ── Copy button ── */
      .pre-wrap {
        position: relative;
      }
      .copy-btn {
        position: absolute;
        top: 0.6rem;
        right: 0.6rem;
        padding: 0.25rem 0.6rem;
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.6875rem;
        background: #1F1F1F;
        color: #888888;
        border: 1px solid #2a2a2a;
        border-radius: 0.375rem;
        cursor: pointer;
        transition: background 0.15s ease, color 0.15s ease, border-color 0.15s ease;
        z-index: 10;
      }
      .copy-btn:hover {
        background: #2a2a2a;
        color: #F0F0F0;
        border-color: #888;
      }
      .copy-btn.copied {
        color: #00FFC8;
        border-color: #00FFC820;
      }

      /* ── Lightbox ── */
      #lightbox {
        display: none;
        opacity: 0;
        transition: opacity 0.2s ease;
      }
      #lightbox.lb-open {
        display: flex;
        opacity: 1;
      }
      #lightbox-content {
        transform: scale(0.95);
        transition: transform 0.2s ease;
      }
      #lightbox.lb-open #lightbox-content {
        transform: scale(1);
      }
      #lightbox-img {
        max-width: 90vw;
        max-height: 90vh;
        object-fit: contain;
        border-radius: 0.5rem;
        display: block;
      }
      .lb-btn {
        width: 2.75rem;
        height: 2.75rem;
        border-radius: 9999px;
        background: rgba(31, 31, 31, 0.8);
        border: 1px solid #2a2a2a;
        color: #f0f0f0;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        flex-shrink: 0;
        transition: background 0.15s ease, border-color 0.15s ease;
      }
      .lb-btn:hover {
        background: rgba(50, 50, 50, 0.9);
        border-color: #888;
      }
      .lb-btn:disabled {
        opacity: 0.3;
        cursor: default;
      }
      #lightbox-close {
        position: absolute;
        top: 1rem;
        right: 1rem;
      }

      .screenshot-wrap {
        overflow: hidden;
        border-radius: 0.5rem;
        border: 1px solid #1F1F1F;
        cursor: pointer;
        transition: border-color 0.2s ease;
      }
      .screenshot-wrap:hover {
        border-color: #888888;
      }
      .screenshot-wrap img {
        width: 100%;
        aspect-ratio: 16/9;
        object-fit: cover;
        display: block;
        transition: transform 0.3s ease;
      }
      .screenshot-wrap:hover img {
        transform: scale(1.03);
      }
    </style>
  </head>

  <body class="font-sans antialiased">

    <!-- ─── NAV ─────────────────────────────────────────────────────────── -->
    <header class="fixed top-0 inset-x-0 z-50 border-b border-[#1F1F1F]/60 bg-[#0D0D0D]/80 backdrop-blur-md">
