---
import "../../styles/global.css";
const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="Endless Runner — Unity 3D infinite runner with chunk-based procedural generation, zero-allocation object pooling, and a fully event-driven architecture."
    />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <title>Endless Runner — Marko Stankovic</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Geist:wght@300;400;500;600;700&family=JetBrains+Mono:ital,wght@0,400;0,500;0,600;0,700&display=swap"
      rel="stylesheet"
    />

    <!-- highlight.js -->
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.10.0/styles/github-dark.min.css"
    />
    <script src="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.10.0/highlight.min.js"></script>

    <style>
      /* ── Code block overrides ── */
      pre code.hljs {
        background: #141414;
        border: 1px solid #1F1F1F;
        border-radius: 0.5rem;
        font-size: 0.8125rem;
        line-height: 1.6;
        padding: 1.25rem 1.5rem;
      }

      /* ── Lightbox ── */
      #lightbox {
        display: none;
        opacity: 0;
        transition: opacity 0.2s ease;
      }
      #lightbox.lb-open {
        display: flex;
        opacity: 1;
      }
      #lightbox-content {
        transform: scale(0.95);
        transition: transform 0.2s ease;
      }
      #lightbox.lb-open #lightbox-content {
        transform: scale(1);
      }
      #lightbox-img {
        max-width: 90vw;
        max-height: 90vh;
        object-fit: contain;
        border-radius: 0.5rem;
        display: block;
      }
      .lb-btn {
        width: 2.75rem;
        height: 2.75rem;
        border-radius: 9999px;
        background: rgba(31, 31, 31, 0.8);
        border: 1px solid #2a2a2a;
        color: #f0f0f0;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        flex-shrink: 0;
        transition: background 0.15s ease, border-color 0.15s ease;
      }
      .lb-btn:hover {
        background: rgba(50, 50, 50, 0.9);
        border-color: #888;
      }
      .lb-btn:disabled {
        opacity: 0.3;
        cursor: default;
      }
      #lightbox-close {
        position: absolute;
        top: 1rem;
        right: 1rem;
      }

      /* ── Screenshot grid images ── */
      .screenshot-wrap {
        overflow: hidden;
        border-radius: 0.5rem;
        border: 1px solid #1F1F1F;
        cursor: pointer;
        transition: border-color 0.2s ease;
      }
      .screenshot-wrap:hover {
        border-color: #888888;
      }
      .screenshot-wrap img {
        width: 100%;
        aspect-ratio: 16/9;
        object-fit: cover;
        display: block;
        transition: transform 0.3s ease;
      }
      .screenshot-wrap:hover img {
        transform: scale(1.03);
      }
    </style>
  </head>

  <body class="font-sans antialiased">

    <!-- ─── NAV ─────────────────────────────────────────────────────────── -->
