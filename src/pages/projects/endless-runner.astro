      </nav>

      <div id="mobile-nav" aria-hidden="true">
        <div class="max-w-5xl mx-auto px-6 py-2 flex flex-col">
          <a href="/"          class="mobile-nav-link py-3 text-sm text-[#888888] hover:text-[#00FFC8] border-b border-[#1F1F1F] transition-colors duration-150 min-h-[44px] flex items-center">← Back to Portfolio</a>
          <a href="/#skills"   class="mobile-nav-link py-3 text-sm text-[#888888] hover:text-[#F0F0F0] border-b border-[#1F1F1F] transition-colors duration-150 min-h-[44px] flex items-center">Skills</a>
          <a href="/#projects" class="mobile-nav-link py-3 text-sm text-[#888888] hover:text-[#F0F0F0] border-b border-[#1F1F1F] transition-colors duration-150 min-h-[44px] flex items-center">Projects</a>
          <a href="/devlog"    class="mobile-nav-link py-3 text-sm text-[#888888] hover:text-[#F0F0F0] border-b border-[#1F1F1F] transition-colors duration-150 min-h-[44px] flex items-center">Devlog</a>
          <a href="/#contact"  class="mobile-nav-link py-3 text-sm text-[#888888] hover:text-[#F0F0F0] transition-colors duration-150 min-h-[44px] flex items-center">Contact</a>
        </div>
      </div>
    </header>

    <!-- ─── HERO ──────────────────────────────────────────────────────────── -->
    <div class="relative pt-14">
      <div class="absolute inset-0 overflow-hidden pointer-events-none" aria-hidden="true">
        <div class="absolute top-1/3 right-1/4 w-[600px] h-[600px] bg-cyan-500/5 rounded-full blur-3xl"></div>
        <div class="absolute top-1/2 left-1/3 w-[300px] h-[300px] bg-[#00FFC8]/3 rounded-full blur-3xl"></div>
      </div>

      <div class="relative max-w-5xl mx-auto px-6 py-20">
        <p class="hero-enter text-[#444444] font-mono text-xs mb-6 tracking-wide" style="--delay: 0.05s">
          Projects / Endless Runner
        </p>

        <div class="hero-enter flex flex-wrap gap-2 mb-6" style="--delay: 0.15s">
          <span class="text-xs font-mono bg-cyan-500/10 text-cyan-400 border border-cyan-500/20 px-3 py-1 rounded-full">
            Completed · Bachelor's Thesis 2025
          </span>
          <span class="text-xs font-mono bg-violet-500/10 text-violet-400 border border-violet-500/20 px-3 py-1 rounded-full">
            Unity 2022 · URP
          </span>
        </div>

        <h1 class="hero-enter font-mono font-bold text-[#F0F0F0] mb-5" style="font-size: clamp(2.5rem, 6vw, 4.5rem); line-height: 1.05; letter-spacing: -0.02em; --delay: 0.3s">
          Endless Runner
        </h1>

        <p class="hero-enter text-[#888888] text-lg max-w-2xl leading-relaxed mb-8" style="--delay: 0.5s">
          The world scrolls, the player stays fixed — <code class="font-mono text-[#00FFC8] text-base bg-[#00FFC8]/10 px-1.5 rounded">LevelGenerator</code> moves chunks toward a stationary <code class="font-mono text-[#00FFC8] text-base bg-[#00FFC8]/10 px-1.5 rounded">PlayerController</code>, each chunk self-manages its pooled obstacles in <code class="font-mono text-[#00FFC8] text-base bg-[#00FFC8]/10 px-1.5 rounded">OnEnable/OnDisable</code>, and difficulty escalates via an exponentially decaying spawn interval.
        </p>

        <div class="hero-enter" style="--delay: 0.65s">
          <a
            href="https://github.com/Idzuo32/DiplomskiRad"
            target="_blank"
            rel="noopener noreferrer"
            class="github-link inline-flex items-center gap-2 px-5 py-2.5 rounded-lg border border-[#1F1F1F] hover:border-[#888888] text-sm text-[#888888] hover:text-[#F0F0F0] transition-colors duration-150"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/>
            </svg>
            View on GitHub
            <svg class="arrow w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
            </svg>
          </a>
        </div>
      </div>
    </div>

    <!-- ─── OVERVIEW MEDIA ────────────────────────────────────────────────── -->
    <div class="border-t border-[#1F1F1F]/50 py-12">
      <div class="max-w-4xl mx-auto px-6">
        <div class="reveal rounded-xl overflow-hidden border border-[#1F1F1F] bg-[#141414]">
          <video
            class="w-full aspect-video object-cover"
            autoplay
            loop
            muted
            playsinline
            preload="metadata"
            poster={`${base}assets/screenshots/endless-runner-1.png`}
          >
            <source src={`${base}assets/thumbnails/endless-runner-thumb.mp4`} type="video/mp4" />
          </video>
        </div>
        <p class="reveal text-[#444444] text-xs font-mono mt-3 text-center" style="--delay: 100ms">
          Gameplay preview — world scrolling, obstacle pool recycling, checkpoint difficulty spike
        </p>
      </div>
    </div>

    <!-- ─── THE PROBLEM ───────────────────────────────────────────────────── -->
    <section id="problem" class="py-20 border-t border-[#1F1F1F]/50">
      <div class="max-w-5xl mx-auto px-6">
        <h2 class="reveal text-2xl font-bold text-[#F0F0F0] mb-10">The Problem</h2>

        <div class="reveal max-w-3xl space-y-5 text-[#888888] leading-relaxed" style="--delay: 100ms">
          <p>
            Infinite generation has one hard constraint: the active object count must stay constant regardless of how long the run lasts. Spawning a new prefab for every obstacle would cause GC pauses that players feel as hitches. A <code class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1 rounded">Queue</code>-based <code class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1 rounded">ObjectPool</code>, managed by a static <code class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1 rounded">PoolManager</code> keyed by prefab, pre-warms instances at load time and then recycles without ever calling <code class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1 rounded">Instantiate</code> again during play. Each <code class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1 rounded">PooledObject</code> component acts as a type tag so <code class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1 rounded">PoolManager.Release()</code> can recursively return a chunk and all its children in one call.
          </p>
          <p>
            Moving the player forward while keeping the camera fixed would require adding a camera-follow system and managing floating-point precision over long distances. A simpler inversion: keep the <code class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1 rounded">PlayerController</code> at a fixed world position and move the chunks toward it. <code class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1 rounded">LevelGenerator</code> translates every active chunk by <code class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1 rounded">-Vector3.forward * moveSpeed * dt</code> in <code class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1 rounded">Update()</code> and recycles via <code class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1 rounded">PoolManager.Release()</code> when a chunk passes the camera.
          </p>
          <p>
            Difficulty had to feel like a smooth curve, not a step function. Each <code class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1 rounded">Checkpoint</code> trigger decreases <code class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1 rounded">ObstacleSpawner.obstacleSpawnTime</code> by an exponentially decaying amount — the first checkpoints feel dangerous, later ones barely tighten the interval — and simultaneously increases world speed while pushing <code class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1 rounded">Physics.gravity.z</code> and camera FOV for visceral speed feedback.
          </p>
        </div>
      </div>
    </section>

    <!-- ─── ARCHITECTURE ──────────────────────────────────────────────────── -->
    <section id="architecture" class="py-20 border-t border-[#1F1F1F]/50">
      <div class="max-w-5xl mx-auto px-6">
        <h2 class="reveal text-2xl font-bold text-[#F0F0F0] mb-10">Architecture</h2>

        <div class="space-y-14">

          <!-- Decision 1: LevelGenerator + Chunk -->
          <div class="reveal" style="--delay: 0ms">
            <div class="border border-[#1F1F1F] rounded-xl p-8">
              <h3 class="font-mono font-semibold text-[#F0F0F0] text-lg mb-3">
                LevelGenerator + Chunk — World Scrolls, Player Stays Fixed
              </h3>
              <p class="text-[#888888] leading-relaxed mb-6 max-w-3xl">
                <code class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1 rounded">LevelGenerator</code> maintains a <code class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1 rounded">List&lt;GameObject&gt; chunks</code>, moves them each frame, and recycles the rearmost chunk when it passes the camera. Every <code class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1 rounded">checkpointChunkInterval</code> spawns it places a <code class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1 rounded">checkpointChunkPrefab</code> instead of a standard chunk. Each <code class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1 rounded">Chunk</code> handles its own content entirely in <code class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1 rounded">OnEnable/OnDisable</code> — no external system tells it what to spawn or clean up.
              </p>
              <pre><code class="language-csharp" set:text={`// Proc Gen/LevelGenerator.cs (namespace ProceduralGeneration)
public class LevelGenerator : MonoBehaviour
{
    [SerializeField] GameObject[]  chunkPrefabs;
    [SerializeField] GameObject    checkpointChunkPrefab;
    [SerializeField] int           startingChunksAmount = 12;
    [SerializeField] int           checkpointChunkInterval = 8;
    [SerializeField] float         chunkLength = 10f;

    float moveSpeed = 10f;
    readonly List<GameObject> chunks = new();
    int chunksSpawned;

    void Update()
    {
        MoveChunks();
        if (ChunkPassedCamera()) RecycleAndSpawn();
    }

    void MoveChunks()
    {
        foreach (var chunk in chunks)
            chunk.transform.position -= Vector3.forward * moveSpeed * Time.deltaTime;
    }

    GameObject ChooseChunkToSpawn() =>
        chunksSpawned % checkpointChunkInterval == 0
            ? checkpointChunkPrefab
            : chunkPrefabs[Random.Range(0, chunkPrefabs.Length)];

    void SpawnChunk()
    {
        var prefab = ChooseChunkToSpawn();
        var go     = PoolManager.Get(prefab, SpawnPosition(), Quaternion.identity);
        chunks.Add(go);
        chunksSpawned++;
    }

    void RecycleAndSpawn()
    {
        PoolManager.Release(chunks[0]);  // recursive — releases chunk + all children
        chunks.RemoveAt(0);
        SpawnChunk();
    }
}

// Proc Gen/Chunk.cs — self-managing content lifecycle
public class Chunk : MonoBehaviour
{
    float[] lanes = { -2.5f, 0f, 2.5f };  // three fixed X-axis lanes

    void OnEnable()   // called when pool hands this chunk out
    {
        SpawnFences();   // up to 2, random lane selection without replacement
        SpawnApple();    // appleSpawnChance = 0.3f
        SpawnCoins();    // coinSpawnChance  = 0.5f, up to 6 in a line
    }

    void OnDisable()  // called when PoolManager.Release() deactivates this chunk
    {
        // PoolManager.Release() already handles recursive child release
        // clearing the spawnRoot children here is a safety cleanup
    }
}`}></code></pre>
            </div>
          </div>

          <!-- Decision 2: ObjectPool + PoolManager + PooledObject -->
          <div class="reveal" style="--delay: 50ms">
            <div class="border border-[#1F1F1F] rounded-xl p-8">
              <h3 class="font-mono font-semibold text-[#F0F0F0] text-lg mb-3">
                ObjectPool + PoolManager + PooledObject — Queue-Based, Keyed by Prefab
              </h3>
              <p class="text-[#888888] leading-relaxed mb-6 max-w-3xl">
                <code class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1 rounded">ObjectPool</code> is a plain class (not a MonoBehaviour) using a <code class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1 rounded">Queue&lt;GameObject&gt;</code> — FIFO recycling means the longest-inactive object is reused first, distributing heat evenly. The static <code class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1 rounded">PoolManager</code> maps each prefab <code class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1 rounded">GameObject</code> to its pool and creates pools on first use with no pre-registration. <code class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1 rounded">PooledObject</code> is added as a component tag during <code class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1 rounded">CreateInstance()</code>, storing the prefab key — this lets <code class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1 rounded">Release()</code> recursively return nested pooled children before returning the parent.
              </p>
              <pre><code class="language-csharp" set:text={`// Pooling/ObjectPool.cs (namespace Pooling) — plain class, not MonoBehaviour
public class ObjectPool
{
    readonly GameObject        _prefab;
    readonly Transform         _poolRoot;
    readonly Queue<GameObject> _items = new();

    public ObjectPool(GameObject prefab, Transform poolRoot, int prewarm = 0)
    {
        _prefab   = prefab;
        _poolRoot = poolRoot;
        for (int i = 0; i < prewarm; i++) _items.Enqueue(CreateInstance());
    }

    public GameObject Get(Vector3 position, Quaternion rotation, Transform parent)
    {
        var go = _items.Count > 0 ? _items.Dequeue() : CreateInstance();
        go.transform.SetPositionAndRotation(position, rotation);
        go.transform.SetParent(parent);
        go.SetActive(true);
        return go;
    }

    public void Return(GameObject go)
    {
        go.SetActive(false);
        go.transform.SetParent(_poolRoot);
        _items.Enqueue(go);
    }

    GameObject CreateInstance()
    {
        var go = Object.Instantiate(_prefab, _poolRoot);
        go.SetActive(false);
        if (!go.TryGetComponent<PooledObject>(out _))
            go.AddComponent<PooledObject>().PrefabKey = _prefab;
        return go;
    }
}

// Managers/PoolManager.cs — static registry, one pool per prefab
public static class PoolManager
{
    static readonly Dictionary<GameObject, ObjectPool> Pools = new();
    static Transform _root;
    static Transform Root   // lazy DontDestroyOnLoad container
    {
        get
        {
            if (_root == null)
            {
                _root = new GameObject("[PoolManager]").transform;
                Object.DontDestroyOnLoad(_root.gameObject);
            }
            return _root;
        }
    }

    public static GameObject Get(GameObject prefab, Vector3 pos, Quaternion rot,
                                  Transform parent = null)
    {
        if (!Pools.TryGetValue(prefab, out var pool))
            Pools[prefab] = pool = new ObjectPool(prefab, Root);
        return pool.Get(pos, rot, parent);
    }

    public static void Release(GameObject go)
    {
        // Recursively release pooled children before returning parent
        foreach (Transform child in go.transform)
            ReleaseIfPooled(child.gameObject);

        if (go.TryGetComponent<PooledObject>(out var pooled))
            Pools[pooled.PrefabKey].Return(go);
    }
}`}></code></pre>
            </div>
          </div>

          <!-- Decision 3: Difficulty escalation -->
          <div class="reveal" style="--delay: 100ms">
            <div class="border border-[#1F1F1F] rounded-xl p-8">
              <h3 class="font-mono font-semibold text-[#F0F0F0] text-lg mb-3">
                Difficulty Escalation — Checkpoints, Gravity, and Exponential Decay
              </h3>
              <p class="text-[#888888] leading-relaxed mb-6 max-w-3xl">
                Each <code class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1 rounded">Checkpoint</code> that the player passes triggers two things: <code class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1 rounded">GameManager.IncreaseTime()</code> (time reward) and <code class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1 rounded">ObstacleSpawner.DecreaseObstacleSpawnTime()</code> (difficulty increase). The decrease amount starts at <code class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1 rounded">0.1f</code> and is multiplied by <code class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1 rounded">decayRate=0.8f</code> each checkpoint — so early checkpoints are punishing and later ones barely change the interval. <code class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1 rounded">LevelGenerator.ApplySpeedDelta()</code> also adjusts <code class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1 rounded">Physics.gravity.z</code> and calls <code class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1 rounded">CameraController.ChangeCameraFOV()</code> to make speed increases feel physical.
              </p>
              <pre><code class="language-csharp" set:text={`// Proc Gen/ObstacleSpawner.cs
public class ObstacleSpawner : MonoBehaviour
{
    [SerializeField] float obstacleSpawnTime    = 1f;
    [SerializeField] float minObstacleSpawnTime = 0.2f;
    [SerializeField] float initialDecreaseAmount = 0.1f;
    [SerializeField] float decayRate             = 0.8f;
    [SerializeField] float minimumDecreaseAmount = 0.01f;

    float currentDecreaseAmount;

    void Start() => currentDecreaseAmount = initialDecreaseAmount;

    // Called by Checkpoint.OnTriggerEnter() each time the player passes a checkpoint
    public void DecreaseObstacleSpawnTime()
    {
        obstacleSpawnTime = Mathf.Max(obstacleSpawnTime - currentDecreaseAmount,
                                      minObstacleSpawnTime);
        // Exponential decay: each call has less impact than the last
        currentDecreaseAmount = Mathf.Max(currentDecreaseAmount * decayRate,
                                           minimumDecreaseAmount);
    }
}

// Proc Gen/Checkpoint.cs
public class Checkpoint : MonoBehaviour
{
    [SerializeField] float checkpointTimeExtension = 5f;

    void OnTriggerEnter(Collider other)
    {
        GameManager.Instance.IncreaseTime(checkpointTimeExtension);
        _obstacleSpawner.DecreaseObstacleSpawnTime();
    }
}

// Proc Gen/LevelGenerator.cs — speed coupled to gravity + FOV
float ApplySpeedDelta(float delta)
{
    float clamped = Mathf.Clamp(moveSpeed + delta, minMoveSpeed, maxMoveSpeed);
    float applied = clamped - moveSpeed;
    moveSpeed     = clamped;

    // Remap speed to gravity.z — faster world = stronger Z pull
    float t = Mathf.InverseLerp(minMoveSpeed, maxMoveSpeed, moveSpeed);
    Physics.gravity = new Vector3(0, Physics.gravity.y,
                                  Mathf.Lerp(minGravityZ, maxGravityZ, t));
    cameraController.ChangeCameraFOV(applied);
    return applied;
}`}></code></pre>
            </div>
          </div>

          <!-- Decision 4: PlayerController analog movement -->
          <div class="reveal" style="--delay: 150ms">
            <div class="border border-[#1F1F1F] rounded-xl p-8">
              <h3 class="font-mono font-semibold text-[#F0F0F0] text-lg mb-3">
                PlayerController — Analog X Clamping, Not Discrete Lanes
              </h3>
              <p class="text-[#888888] leading-relaxed mb-6 max-w-3xl">
                <code class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1 rounded">PlayerController</code> reads a <code class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1 rounded">Vector2</code> from <code class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1 rounded">InputManager.MoveEvent</code>, scales it by <code class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1 rounded">moveSpeed</code>, and moves the Rigidbody on the X axis only — clamped to <code class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1 rounded">±xClamp=3f</code>. Movement is analog, not discrete: holding a direction slides the player to the edge rather than snapping to a lane center. The <code class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1 rounded">Chunk</code> obstacles are placed at three fixed X positions (<code class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1 rounded">-2.5f, 0f, 2.5f</code>) so the player can dodge without snapping — you pass between fences by reading lane width rather than pressing a lane key.
              </p>
              <pre><code class="language-csharp" set:text={`// Player/PlayerController.cs (namespace Player)
[RequireComponent(typeof(Rigidbody))]
public class PlayerController : MonoBehaviour
{
    [SerializeField] float moveSpeed = 5f;
    [SerializeField] float xClamp    = 3f;   // hard edge at ±3 world units

    Vector2   movement;
    Rigidbody rigidBody;
    bool      canControl = false;

    void OnEnable()
    {
        // Subscribes to static events — no direct reference to InputManager scene object
        InputManager.Instance.MoveEvent   += HandleMove;
        GameManager.OnGameStart            += () => canControl = true;
        GameManager.OnGameOver             += () => canControl = false;
    }

    void HandleMove(Vector2 dir) => movement = dir;

    void FixedUpdate()
    {
        if (!canControl) return;
        HandleMovement();
    }

    void HandleMovement()
    {
        Vector3 pos = rigidBody.position;
        pos.x = Mathf.Clamp(pos.x + movement.x * moveSpeed * Time.fixedDeltaTime,
                             -xClamp, xClamp);
        rigidBody.MovePosition(pos);
    }
}

// Chunk obstacle lane positions for reference:
// float[] lanes = { -2.5f, 0f, 2.5f }  →  Chunk.cs`}></code></pre>
