          <a href="/#skills"   class="mobile-nav-link py-3 text-sm text-[#888888] hover:text-[#F0F0F0] border-b border-[#1F1F1F] transition-colors duration-150 min-h-[44px] flex items-center">Skills</a>
          <a href="/#projects" class="mobile-nav-link py-3 text-sm text-[#888888] hover:text-[#F0F0F0] border-b border-[#1F1F1F] transition-colors duration-150 min-h-[44px] flex items-center">Projects</a>
          <a href="/devlog"    class="mobile-nav-link py-3 text-sm text-[#888888] hover:text-[#F0F0F0] border-b border-[#1F1F1F] transition-colors duration-150 min-h-[44px] flex items-center">Devlog</a>
          <a href="/#contact"  class="mobile-nav-link py-3 text-sm text-[#888888] hover:text-[#F0F0F0] transition-colors duration-150 min-h-[44px] flex items-center">Contact</a>
        </div>
      </div>
    </header>

    <!-- ─── HERO ──────────────────────────────────────────────────────────── -->
    <div class="relative pt-14">
      <div class="absolute inset-0 overflow-hidden pointer-events-none" aria-hidden="true">
        <div class="absolute top-1/3 left-1/4 w-[600px] h-[600px] bg-violet-600/5 rounded-full blur-3xl"></div>
        <div class="absolute top-1/2 right-1/3 w-[300px] h-[300px] bg-[#00FFC8]/3 rounded-full blur-3xl"></div>
      </div>

      <div class="relative max-w-5xl mx-auto px-6 py-20">
        <p class="hero-enter text-[#444444] font-mono text-xs mb-6 tracking-wide" style="--delay: 0.05s">
          Projects / Hide &amp; Seek
        </p>

        <div class="hero-enter flex flex-wrap gap-2 mb-6" style="--delay: 0.15s">
          <span class="text-xs font-mono bg-[#00FFC8]/10 text-[#00FFC8] border border-[#00FFC8]/20 px-3 py-1 rounded-full">
            In Development
          </span>
          <span class="text-xs font-mono bg-violet-500/10 text-violet-400 border border-violet-500/20 px-3 py-1 rounded-full">
            Unity 6 · URP
          </span>
        </div>

        <h1 class="hero-enter font-mono font-bold text-[#F0F0F0] mb-5" style="font-size: clamp(2.5rem, 6vw, 4.5rem); line-height: 1.05; letter-spacing: -0.02em; --delay: 0.3s">
          Hide &amp; Seek
        </h1>

        <p class="hero-enter text-[#888888] text-lg max-w-2xl leading-relaxed mb-8" style="--delay: 0.5s">
          Detection isn't a flag — it's a continuous suspicion float with per-state hysteresis, six enemy behaviours driven by a generic <code class="font-mono text-[#00FFC8] text-base bg-[#00FFC8]/10 px-1.5 rounded">StateMachine</code>, and a static noise event bus that decouples every sound source from every listener.
        </p>

        <div class="hero-enter" style="--delay: 0.65s">
          <a
            href="https://github.com/Idzuo32/hide_and_seek_3d"
            target="_blank"
            rel="noopener noreferrer"
            class="github-link inline-flex items-center gap-2 px-5 py-2.5 rounded-lg border border-[#1F1F1F] hover:border-[#888888] text-sm text-[#888888] hover:text-[#F0F0F0] transition-colors duration-150"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/>
            </svg>
            View on GitHub
            <svg class="arrow w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
            </svg>
          </a>
        </div>
      </div>
    </div>

    <!-- ─── OVERVIEW MEDIA ────────────────────────────────────────────────── -->
    <div class="border-t border-[#1F1F1F]/50 py-12">
      <div class="max-w-4xl mx-auto px-6">
        <div class="reveal rounded-xl overflow-hidden border border-[#1F1F1F] bg-[#141414]">
          <video
            class="w-full aspect-video object-cover"
            autoplay
            loop
            muted
            playsinline
            preload="metadata"
            poster={`${base}assets/screenshots/hide-and-seek-1.png`}
          >
            <source src={`${base}assets/thumbnails/hide-and-seek-thumb.mp4`} type="video/mp4" />
          </video>
        </div>
        <p class="reveal text-[#444444] text-xs font-mono mt-3 text-center" style="--delay: 100ms">
          Gameplay preview — suspicion build-up, patrol → investigate → chase sequence
        </p>
      </div>
    </div>

    <!-- ─── THE PROBLEM ───────────────────────────────────────────────────── -->
    <section id="problem" class="py-20 border-t border-[#1F1F1F]/50">
      <div class="max-w-5xl mx-auto px-6">
        <h2 class="reveal text-2xl font-bold text-[#F0F0F0] mb-10">The Problem</h2>

        <div class="reveal max-w-3xl space-y-5 text-[#888888] leading-relaxed" style="--delay: 100ms">
          <p>
            Binary detection — seen or not seen — kills the stealth loop. A player who's caught the moment they step into a cone has no room to react. The suspicion system here is a continuous <code class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1 rounded">float</code> (0–100) with per-state hysteresis: separate rising and falling thresholds per <code class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1 rounded">SeekState</code> prevent flickering and give the player a window to duck behind cover and let the meter bleed back down before the enemy locks on.
          </p>
          <p>
            Six behavioural states — Idle, Patrol, Investigate, Alert, Chase, Search — each need to read from the suspicion meter and NavMesh, play animations, and trigger camera responses, all without knowing about each other. Putting that logic in a monolithic update loop would have collapsed under its own weight. The answer was a generic <code class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1 rounded">StateMachine</code> (a plain C# class, not a MonoBehaviour) paired with an <code class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1 rounded">IState</code> interface — each state is a self-contained class that owns its own enter, tick, and exit logic.
          </p>
          <p>
            Audio detection added a third coupling problem: anything that makes noise (player sprinting, a knocked-over prop) needs to alert any enemy within range, but neither the emitter nor the enemy should hold a reference to the other. A static <code class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1 rounded">NoiseEmitter</code> event bus with a lightweight <code class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1 rounded">NoiseEvent</code> struct solves this: emitters fire-and-forget, listeners filter by distance, and neither side is aware of the other.
          </p>
        </div>
      </div>
    </section>

    <!-- ─── ARCHITECTURE ──────────────────────────────────────────────────── -->
    <section id="architecture" class="py-20 border-t border-[#1F1F1F]/50">
      <div class="max-w-5xl mx-auto px-6">
        <h2 class="reveal text-2xl font-bold text-[#F0F0F0] mb-10">Architecture</h2>

        <div class="space-y-14">

          <!-- Decision 1: IState + StateMachine -->
          <div class="reveal" style="--delay: 0ms">
            <div class="border border-[#1F1F1F] rounded-xl p-8">
              <h3 class="font-mono font-semibold text-[#F0F0F0] text-lg mb-3">
                IState + StateMachine — Plain Classes, Not MonoBehaviours
              </h3>
              <p class="text-[#888888] leading-relaxed mb-6 max-w-3xl">
                The state machine lives in <code class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1 rounded">Infrastructure/StateMachine/</code> as two plain C# classes with no Unity dependency. <code class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1 rounded">StateMachine</code> holds the current state and calls <code class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1 rounded">Exit()</code> then <code class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1 rounded">Enter()</code> on transition. <code class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1 rounded">EnemyController</code> owns one and calls <code class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1 rounded">Tick()</code> from <code class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1 rounded">Update()</code>. All six concrete states extend <code class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1 rounded">BaseState</code> and are constructed with a reference to their owner <code class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1 rounded">EnemyController</code>.
              </p>
              <pre><code class="language-csharp" set:text={`// Infrastructure/Interfaces/IState.cs
public interface IState
{
    void Enter();
    void Tick();
    void Exit();
}

// Infrastructure/StateMachine/StateMachine.cs
public class StateMachine
{
    IState _currentState;
    public IState CurrentState => _currentState;

    public void ChangeState(IState newState)
    {
        _currentState?.Exit();
        _currentState = newState;
        _currentState?.Enter();
    }

    public void Tick() => _currentState?.Tick();
}

// Infrastructure/StateMachine/BaseState.cs
public abstract class BaseState : IState
{
    public virtual void Enter() { }
    public virtual void Tick()  { }
    public virtual void Exit()  { }
}

// AI/Enemy/EnemyController.cs (simplified)
public class EnemyController : MonoBehaviour
{
    StateMachine _stateMachine = new();

    void Start() => _stateMachine.ChangeState(new EnemyPatrolState(this));
    void Update() => _stateMachine.Tick();

    public void ChangeState(IState newState) => _stateMachine.ChangeState(newState);
}`}></code></pre>
              <!-- Concrete states -->
              <div class="mt-6 p-4 bg-[#0D0D0D] rounded-lg border border-[#1F1F1F]">
                <p class="text-[#444444] text-xs font-mono mb-3">Six concrete states in AI/Enemy/States/</p>
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-2">
                  {[
                    ["EnemyIdleState",        "Stops nav · waits timer · → Patrol"],
                    ["EnemyPatrolState",      "Walks waypoints · → Alert/Chase on suspicion"],
                    ["EnemyInvestigateState", "Moves to position · → Patrol after look"],
                    ["EnemyAlertState",       "Stops · scans toward LKP · → Chase/Search"],
                    ["EnemyChaseState",       "Throttled nav update · → Search on lost"],
                    ["EnemySearchState",      "3-phase: LKP → sweep N dirs → nearest waypoints"],
                  ].map(([name, desc]) => (
                    <div class="flex gap-3 text-xs">
                      <code class="font-mono text-violet-400 shrink-0">{name}</code>
                      <span class="text-[#444444]">{desc}</span>
                    </div>
                  ))}
                </div>
              </div>
            </div>
          </div>

          <!-- Decision 2: SuspicionMeter -->
          <div class="reveal" style="--delay: 50ms">
            <div class="border border-[#1F1F1F] rounded-xl p-8">
              <h3 class="font-mono font-semibold text-[#F0F0F0] text-lg mb-3">
                SuspicionMeter — Continuous Float with Hysteresis
              </h3>
              <p class="text-[#888888] leading-relaxed mb-6 max-w-3xl">
                <code class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1 rounded">SuspicionMeter</code> is a MonoBehaviour on the enemy that accumulates suspicion each <code class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1 rounded">FixedUpdate</code>. Visual delta (from <code class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1 rounded">EnemyDetection.ComputeVisualDelta()</code>) accounts for distance falloff, angle falloff, and crouch stealth modifier. <code class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1 rounded">ComputeTargetState()</code> uses separate rising/falling thresholds per state — e.g. <code class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1 rounded">alertThreshold=25f</code> to enter Alert but <code class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1 rounded">alertRevertThreshold=15f</code> to leave it — preventing rapid state flickering at threshold boundaries.
              </p>
              <pre><code class="language-csharp" set:text={`// Detection/SuspicionMeter.cs
public class SuspicionMeter : MonoBehaviour
{
    public event Action<float>            OnSuspicionChanged;
    public event Action<SeekState, SeekState> OnStateChanged;
    public event Action                   OnPlayerCaught;

    public float     Suspicion           { get; private set; }  // 0–100
    public float     SuspicionNormalized => Suspicion / 100f;
    public SeekState State               { get; private set; }
    public float     Phase2SuspicionFloor { get; set; }         // set by LevelPhaseManager

    // Called each FixedUpdate by EnemyDetection
    public void Tick(float visualDeltaPerSec, float audioSpike,
                     bool hasLoS, float proximityDeltaPerSec,
                     bool playerInCatchRadius) { /* ... */ }

    SeekState ComputeTargetState()
    {
        // Rising thresholds (from EnemyData ScriptableObject):
        //   Unaware → Alert:     suspicion >= alertThreshold     (25f)
        //   Alert   → Searching: suspicion >= searchingThreshold (60f)
        //   Searching → Chase:   suspicion >= chaseThreshold     (85f)
        //
        // Falling thresholds (hysteresis gap prevents flickering):
        //   Chase   → Searching: suspicion < chaseRevertThreshold     (75f)
        //   Searching → Alert:   suspicion < searchingRevertThreshold  (50f)
        //   Alert   → Unaware:   suspicion < alertRevertThreshold      (15f)
        // ...
    }
}

// AI/Enemy/EnemyDetection.cs — visual delta per GDD formula F2
float ComputeVisualDelta(float distance, float angleToPlayer)
{
    // distanceFactor: falloff using distanceFalloffExponent (2f) over detectionRange (15f)
    // angleFactor:    falloff using angleFalloffExponent (2f)   over fieldOfViewAngle/2 (45°)
    // crouchModifier: crouchStealthMultiplier (0.4f) when player is crouching
    // stateMultiplier: searchingVisualDetectionMultiplier (1.5f) when Searching
    // [VERIFY exact formula in EnemyDetection.cs]
    return data.baseDetectionRate * distanceFactor * angleFactor
               * crouchModifier * stateMultiplier;
}`}></code></pre>
            </div>
          </div>

          <!-- Decision 3: EnemyNavigation wrapper + NoiseEmitter bus -->
          <div class="reveal" style="--delay: 100ms">
            <div class="border border-[#1F1F1F] rounded-xl p-8">
              <h3 class="font-mono font-semibold text-[#F0F0F0] text-lg mb-3">
                Decoupled Subsystems — EnemyNavigation Wrapper &amp; NoiseEmitter Bus
              </h3>
              <p class="text-[#888888] leading-relaxed mb-6 max-w-3xl">
                States never touch <code class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1 rounded">NavMeshAgent</code> directly. <code class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1 rounded">EnemyNavigation</code> wraps it and adds <code class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1 rounded">RotateToward()</code> (returns true when within 1°, used by Alert scan) and <code class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1 rounded">IsNear()</code>. Audio detection works the same way: <code class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1 rounded">NoiseEmitter</code> is a static class that fires a <code class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1 rounded">readonly struct</code> event — <code class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1 rounded">NoiseEvent</code> — and each enemy's <code class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1 rounded">NoiseListener</code> filters by <code class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1 rounded">_hearingRadius</code> before raising its own local event. The <code class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1 rounded">NoiseEvent</code> struct allocates nothing on the heap.
              </p>
              <pre><code class="language-csharp" set:text={`// AI/Enemy/EnemyNavigation.cs
[RequireComponent(typeof(NavMeshAgent))]
public class EnemyNavigation : MonoBehaviour
{
    NavMeshAgent _agent;

    public bool IsAtDestination { get; }

    public void SetDestination(Vector3 position) => _agent.SetDestination(position);
    public void SetSpeed(float speed)            => _agent.speed = speed;
    public void Stop()                           => _agent.ResetPath();

    public bool IsNear(Vector3 position, float threshold) =>
        Vector3.Distance(transform.position, position) <= threshold;

    // Used by EnemyAlertState to scan toward last-known-position
    public bool RotateToward(Vector3 target, float degreesPerSecond) { /* returns true when < 1° */ }
}

// Detection/NoiseSystem/NoiseEvent.cs — heap-free event payload
public readonly struct NoiseEvent
{
    public Vector3 WorldPosition { get; init; }
    public float   Intensity     { get; init; }
    public string  SourceTag     { get; init; }
}

// Detection/NoiseSystem/NoiseEmitter.cs — static fire-and-forget bus
public static class NoiseEmitter
{
    public static event Action<NoiseEvent> OnNoiseEmitted;
    public static void Emit(NoiseEvent e) => OnNoiseEmitted?.Invoke(e);
}

// Detection/NoiseSystem/NoiseListener.cs — per-enemy filtered subscriber
public class NoiseListener : MonoBehaviour
{
    [SerializeField] float _hearingRadius;
    public event Action<NoiseEvent> OnNoiseHeard;

    void OnEnable()  => NoiseEmitter.OnNoiseEmitted += HandleNoise;
    void OnDisable() => NoiseEmitter.OnNoiseEmitted -= HandleNoise;

    void HandleNoise(NoiseEvent e)
    {
        if (Vector3.Distance(transform.position, e.WorldPosition) <= _hearingRadius)
            OnNoiseHeard?.Invoke(e);
    }
}`}></code></pre>
            </div>
          </div>

          <!-- Decision 4: LevelBuilder editor suite -->
