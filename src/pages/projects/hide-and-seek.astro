---
import "../../styles/global.css";
const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="Hide & Seek — Unity 3D stealth game with a five-state enemy AI built on the IEnemyState interface pattern. NavMesh pathfinding, Cinemachine, custom editor tooling."
    />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <title>Hide & Seek — Marko Stankovic</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Geist:wght@300;400;500;600;700&family=JetBrains+Mono:ital,wght@0,400;0,500;0,600;0,700&display=swap"
      rel="stylesheet"
    />

    <!-- highlight.js -->
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.10.0/styles/github-dark.min.css"
    />
    <script src="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.10.0/highlight.min.js"></script>

    <style>
      /* ── Code block overrides ── */
      pre code.hljs {
        background: #141414;
        border: 1px solid #1F1F1F;
        border-radius: 0.5rem;
        font-size: 0.8125rem;
        line-height: 1.6;
        padding: 1.25rem 1.5rem;
      }

      /* ── Lightbox ── */
      #lightbox {
        display: none;
        opacity: 0;
        transition: opacity 0.2s ease;
      }
      #lightbox.lb-open {
        display: flex;
        opacity: 1;
      }
      #lightbox-content {
        transform: scale(0.95);
        transition: transform 0.2s ease;
      }
      #lightbox.lb-open #lightbox-content {
        transform: scale(1);
      }
      #lightbox-img {
        max-width: 90vw;
        max-height: 90vh;
        object-fit: contain;
        border-radius: 0.5rem;
        display: block;
      }
      .lb-btn {
        width: 2.75rem;
        height: 2.75rem;
        border-radius: 9999px;
        background: rgba(31, 31, 31, 0.8);
        border: 1px solid #2a2a2a;
        color: #f0f0f0;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        flex-shrink: 0;
        transition: background 0.15s ease, border-color 0.15s ease;
      }
      .lb-btn:hover {
        background: rgba(50, 50, 50, 0.9);
        border-color: #888;
      }
      .lb-btn:disabled {
        opacity: 0.3;
        cursor: default;
      }
      #lightbox-close {
        position: absolute;
        top: 1rem;
        right: 1rem;
      }

      /* ── Screenshot grid images ── */
      .screenshot-wrap {
        overflow: hidden;
        border-radius: 0.5rem;
        border: 1px solid #1F1F1F;
        cursor: pointer;
        transition: border-color 0.2s ease;
      }
      .screenshot-wrap:hover {
        border-color: #888888;
      }
      .screenshot-wrap img {
        width: 100%;
        aspect-ratio: 16/9;
        object-fit: cover;
        display: block;
        transition: transform 0.3s ease;
      }
      .screenshot-wrap:hover img {
        transform: scale(1.03);
      }
    </style>
  </head>

  <body class="font-sans antialiased">

    <!-- ─── NAV ─────────────────────────────────────────────────────────── -->
    <header class="fixed top-0 inset-x-0 z-50 border-b border-[#1F1F1F]/60 bg-[#0D0D0D]/80 backdrop-blur-md">
      <nav class="max-w-5xl mx-auto px-6 h-14 flex items-center justify-between">
        <div class="flex items-center gap-5">
          <a
            href="/"
            class="nav-link text-sm text-[#888888] hover:text-[#00FFC8] transition-colors duration-150 flex items-center gap-1.5"
          >
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
            </svg>
            Back to Portfolio
          </a>
          <span class="text-[#1F1F1F]">|</span>
          <a href="/" class="font-bold font-mono tracking-tight text-[#F0F0F0] text-lg">MS</a>
        </div>

        <!-- Desktop nav -->
        <ul class="hidden sm:flex gap-6 text-sm text-[#888888]">
          <li>
            <a href="/#skills" class="nav-link hover:text-[#F0F0F0] transition-colors duration-150">Skills</a>
          </li>
          <li>
            <a href="/#projects" class="nav-link hover:text-[#F0F0F0] transition-colors duration-150">Projects</a>
          </li>
          <li>
            <a href="/#contact" class="nav-link hover:text-[#F0F0F0] transition-colors duration-150">Contact</a>
          </li>
        </ul>

        <!-- Hamburger (mobile) -->
        <button
          id="menu-btn"
          class="sm:hidden w-11 h-11 flex items-center justify-center text-[#888888] hover:text-[#F0F0F0] transition-colors duration-150"
          aria-label="Toggle menu"
          aria-expanded="false"
        >
          <svg id="icon-menu" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
          </svg>
          <svg id="icon-close" class="w-5 h-5 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
      </nav>

      <!-- Mobile dropdown -->
      <div id="mobile-nav" aria-hidden="true">
        <div class="max-w-5xl mx-auto px-6 py-2 flex flex-col">
          <a href="/" class="mobile-nav-link py-3 text-sm text-[#888888] hover:text-[#00FFC8] border-b border-[#1F1F1F] transition-colors duration-150 min-h-[44px] flex items-center">← Back to Portfolio</a>
          <a href="/#skills" class="mobile-nav-link py-3 text-sm text-[#888888] hover:text-[#F0F0F0] border-b border-[#1F1F1F] transition-colors duration-150 min-h-[44px] flex items-center">Skills</a>
          <a href="/#projects" class="mobile-nav-link py-3 text-sm text-[#888888] hover:text-[#F0F0F0] border-b border-[#1F1F1F] transition-colors duration-150 min-h-[44px] flex items-center">Projects</a>
          <a href="/#contact" class="mobile-nav-link py-3 text-sm text-[#888888] hover:text-[#F0F0F0] transition-colors duration-150 min-h-[44px] flex items-center">Contact</a>
        </div>
      </div>
    </header>

    <!-- ─── HERO ──────────────────────────────────────────────────────────── -->
    <div class="relative pt-14">
      <!-- Decorative glow -->
      <div class="absolute inset-0 overflow-hidden pointer-events-none" aria-hidden="true">
        <div class="absolute top-1/3 left-1/4 w-[600px] h-[600px] bg-violet-600/5 rounded-full blur-3xl"></div>
        <div class="absolute top-1/2 right-1/3 w-[300px] h-[300px] bg-[#00FFC8]/3 rounded-full blur-3xl"></div>
      </div>

      <div class="relative max-w-5xl mx-auto px-6 py-20">
        <!-- Breadcrumb -->
        <p class="hero-enter text-[#444444] font-mono text-xs mb-6 tracking-wide" style="--delay: 0.05s">
          Projects / Hide & Seek
        </p>

        <!-- Badges -->
        <div class="hero-enter flex flex-wrap gap-2 mb-6" style="--delay: 0.15s">
          <span class="text-xs font-mono bg-[#00FFC8]/10 text-[#00FFC8] border border-[#00FFC8]/20 px-3 py-1 rounded-full">
            In Development
          </span>
          <span class="text-xs font-mono bg-violet-500/10 text-violet-400 border border-violet-500/20 px-3 py-1 rounded-full">
            Unity 3D
          </span>
        </div>

        <!-- Project name -->
        <h1 class="hero-enter font-mono font-bold text-[#F0F0F0] mb-5" style="font-size: clamp(2.5rem, 6vw, 4.5rem); line-height: 1.05; letter-spacing: -0.02em; --delay: 0.3s">
          Hide &amp; Seek
        </h1>

        <!-- Hook -->
        <p class="hero-enter text-[#888888] text-lg max-w-2xl leading-relaxed mb-8" style="--delay: 0.5s">
          An enemy AI built on a clean <code class="font-mono text-[#00FFC8] text-base bg-[#00FFC8]/10 px-1.5 rounded">IEnemyState</code> interface — five behavioral states, one NavMeshAgent, and a detection cone that actually feels threatening.
        </p>

        <!-- GitHub link -->
        <div class="hero-enter" style="--delay: 0.65s">
          <a
            href="https://github.com/Idzuo32/hide_and_seek_3d"
            target="_blank"
            rel="noopener noreferrer"
            class="github-link inline-flex items-center gap-2 px-5 py-2.5 rounded-lg border border-[#1F1F1F] hover:border-[#888888] text-sm text-[#888888] hover:text-[#F0F0F0] transition-colors duration-150"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/>
            </svg>
            View on GitHub
            <svg class="arrow w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
            </svg>
          </a>
        </div>
      </div>
    </div>

    <!-- ─── OVERVIEW MEDIA ────────────────────────────────────────────────── -->
    <div class="border-t border-[#1F1F1F]/50 py-12">
      <div class="max-w-4xl mx-auto px-6">
        <div class="reveal rounded-xl overflow-hidden border border-[#1F1F1F] bg-[#141414]">
          <video
            class="w-full aspect-video object-cover"
            autoplay
            loop
            muted
            playsinline
            preload="metadata"
            poster={`${base}assets/screenshots/hide-and-seek-1.png`}
          >
            <source src={`${base}assets/thumbnails/hide-and-seek-thumb.mp4`} type="video/mp4" />
          </video>
        </div>
        <p class="reveal text-[#444444] text-xs font-mono mt-3 text-center" style="--delay: 100ms">
          Gameplay preview — enemy patrol → detection → chase sequence
        </p>
      </div>
    </div>

    <!-- ─── THE PROBLEM ───────────────────────────────────────────────────── -->
    <section id="problem" class="py-20 border-t border-[#1F1F1F]/50">
      <div class="max-w-5xl mx-auto px-6">
        <h2 class="reveal text-2xl font-bold text-[#F0F0F0] mb-10">The Problem</h2>

        <div class="reveal max-w-3xl space-y-5 text-[#888888] leading-relaxed" style="--delay: 100ms">
          <p>
            Building enemy AI that <em class="text-[#F0F0F0] not-italic">feels</em> smart is harder than making it technically correct. The enemy needs to patrol predictably so the player can read it, break into a chase when the player slips up, and transition into a search mode that creates tension without being unfair. Getting those transitions to feel natural — not jarring — required a clean separation between what the enemy <em class="text-[#F0F0F0] not-italic">knows</em> and what it <em class="text-[#F0F0F0] not-italic">does</em>.
          </p>
          <p>
            The detection system added another layer of complexity. A simple radius check collapses the whole stealth loop — the player either is seen or isn't, with no room for skill. The final system uses a cone-based line-of-sight check with raycasts, meaning the player can break line-of-sight mid-chase by ducking behind cover, triggering the Investigate → Search transition instead of a guaranteed catch.
          </p>
          <p>
            Managing five AI states with NavMesh, animations, and Cinemachine camera changes all needing to stay in sync meant the code would get messy fast. The interface-based state machine was the answer — each state owns its own enter/update/exit logic, and <code class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1 rounded">EnemyController</code> never needs to know which state is active.
          </p>
        </div>
      </div>
    </section>

    <!-- ─── ARCHITECTURE ──────────────────────────────────────────────────── -->
    <section id="architecture" class="py-20 border-t border-[#1F1F1F]/50">
      <div class="max-w-5xl mx-auto px-6">
        <h2 class="reveal text-2xl font-bold text-[#F0F0F0] mb-10">Architecture</h2>

        <div class="space-y-14">

          <!-- Decision 1: IEnemyState interface -->
          <div class="reveal" style="--delay: 0ms">
            <div class="bg-[#141414] border border-[#1F1F1F] rounded-xl p-8">
              <h3 class="font-mono font-semibold text-[#F0F0F0] text-lg mb-3">
                Why an Interface over a Behavior Tree
              </h3>
              <p class="text-[#888888] leading-relaxed mb-6 max-w-3xl">
                A Behavior Tree would have been overkill for five states with deterministic transitions. The <code class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1 rounded">IEnemyState</code> interface keeps each state self-contained — it owns its own enter, update, and exit logic. Adding a new state means creating one new class, not modifying a tree. The controller stays at around 40 lines of code regardless of how many states exist.
              </p>
              <pre><code class="language-csharp" set:text={`public interface IEnemyState
{
    void OnEnter(EnemyController enemy);
    void OnUpdate(EnemyController enemy);
    void OnExit(EnemyController enemy);
}

public class ChaseState : IEnemyState
{
    public void OnEnter(EnemyController enemy)
    {
        enemy.Agent.speed = enemy.ChaseSpeed;
        enemy.Animator.SetBool("IsChasing", true);
    }

    public void OnUpdate(EnemyController enemy)
    {
        enemy.Agent.SetDestination(enemy.Target.position);

        if (enemy.DistanceToTarget > enemy.SightRange)
            enemy.TransitionTo(new SearchState());
    }

    public void OnExit(EnemyController enemy)
    {
        enemy.Animator.SetBool("IsChasing", false);
    }
}`}></code></pre>
            </div>
          </div>

          <!-- Decision 2: NavMeshAgent integration -->
          <div class="reveal" style="--delay: 50ms">
            <div class="bg-[#141414] border border-[#1F1F1F] rounded-xl p-8">
              <h3 class="font-mono font-semibold text-[#F0F0F0] text-lg mb-3">
                NavMeshAgent as a Dumb Driver
              </h3>
              <p class="text-[#888888] leading-relaxed mb-6 max-w-3xl">
                <code class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1 rounded">NavMeshAgent</code> handles pathfinding but knows nothing about state. The controller exposes it as a public property so each state can set speed, destination, and stopping distance without coupling to the controller's internals. <code class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1 rounded">TransitionTo()</code> is the only mutating method the controller owns — states call it when their exit condition is met.
              </p>
              <pre><code class="language-csharp" set:text={`public class EnemyController : MonoBehaviour
{
    public NavMeshAgent Agent { get; private set; }
    public Transform Target { get; set; }
    public float DistanceToTarget => Vector3.Distance(transform.position, Target.position);

    [field: SerializeField] public float SightRange  { get; private set; } = 12f;
    [field: SerializeField] public float ChaseSpeed  { get; private set; } = 5.5f;
    [field: SerializeField] public float PatrolSpeed { get; private set; } = 2.5f;

    public Animator Animator { get; private set; }

    private IEnemyState _currentState;

    void Awake()
    {
        Agent    = GetComponent<NavMeshAgent>();
        Animator = GetComponent<Animator>();
    }

    void Start() => TransitionTo(new PatrolState());

    void Update() => _currentState?.OnUpdate(this);

    public void TransitionTo(IEnemyState newState)
    {
        _currentState?.OnExit(this);
        _currentState = newState;
        _currentState.OnEnter(this);
    }
}`}></code></pre>
            </div>
          </div>

          <!-- Decision 3: Cinemachine -->
          <div class="reveal" style="--delay: 100ms">
            <div class="bg-[#141414] border border-[#1F1F1F] rounded-xl p-8">
              <h3 class="font-mono font-semibold text-[#F0F0F0] text-lg mb-3">
                Cinemachine for Reactive Camera Tension
              </h3>
              <p class="text-[#888888] leading-relaxed mb-6 max-w-3xl">
                Two virtual cameras — one for exploration, one for chase — let Cinemachine handle all blending. The camera controller just sets priority; Cinemachine's built-in blending produces smooth transitions without any manual lerping code. The chase camera sits closer and lower, adding urgency without touching a single transform.
              </p>
              <pre><code class="language-csharp" set:text={`public class CameraController : MonoBehaviour
{
    [SerializeField] private CinemachineVirtualCamera _exploreCamera;
    [SerializeField] private CinemachineVirtualCamera _chaseCamera;

    public void SetMode(CameraMode mode)
    {
        // Cinemachine always activates the highest-priority camera
        // and blends automatically — no manual lerp needed
        _exploreCamera.Priority = mode == CameraMode.Explore ? 20 : 10;
        _chaseCamera.Priority   = mode == CameraMode.Chase   ? 20 : 10;
    }
}

public enum CameraMode { Explore, Chase }`}></code></pre>
            </div>
          </div>

          <!-- Decision 4: Custom Editor utilities -->
          <div class="reveal" style="--delay: 150ms">
            <div class="bg-[#141414] border border-[#1F1F1F] rounded-xl p-8">
              <h3 class="font-mono font-semibold text-[#F0F0F0] text-lg mb-3">
                Custom Editor Utilities for Level Layout
              </h3>
              <p class="text-[#888888] leading-relaxed mb-6 max-w-3xl">
                Placing props and room tiles by hand in a top-down level is tedious and error-prone. A custom <code class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1 rounded">Editor</code> script adds two buttons to the <code class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1 rounded">LevelLayout</code> inspector: one to regenerate tiles procedurally from a room template, one to snap all child props to the grid. Iteration that used to take ten minutes now takes ten seconds.
              </p>
              <pre><code class="language-csharp" set:text={`[CustomEditor(typeof(LevelLayout))]
public class LevelLayoutEditor : Editor
{
    public override void OnInspectorGUI()
    {
        base.OnInspectorGUI();

        var layout = (LevelLayout)target;

        EditorGUILayout.Space();

        if (GUILayout.Button("Regenerate Room Tiles"))
        {
            Undo.RecordObject(layout, "Regenerate Tiles");
            layout.RegenerateTiles();
        }

        if (GUILayout.Button("Snap All Props to Grid"))
        {
            Undo.RecordObject(layout, "Snap Props");
            layout.SnapPropsToGrid();
        }
    }
}`}></code></pre>
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- ─── SCREENSHOTS ───────────────────────────────────────────────────── -->
    <section
      id="screenshots"
      class="py-20 border-t border-[#1F1F1F]/50"
      data-screenshots={`${base}assets/screenshots/hide-and-seek-1.png,${base}assets/screenshots/hide-and-seek-2.png`}
    >
      <div class="max-w-5xl mx-auto px-6">
        <h2 class="reveal text-2xl font-bold text-[#F0F0F0] mb-10">Screenshots</h2>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <!-- Screenshot 1 -->
          <div class="reveal" style="--delay: 0ms">
            <div
              class="screenshot-wrap"
              role="button"
              tabindex="0"
              aria-label="Open screenshot 1"
              data-index="0"
            >
              <img
                src={`${base}assets/screenshots/hide-and-seek-1.png`}
                alt="Hide and Seek — top-down gameplay view"
                loading="lazy"
              />
            </div>
            <p class="text-[#444444] text-xs font-mono mt-2">Top-down gameplay — patrol route visible</p>
          </div>

          <!-- Screenshot 2 -->
          <div class="reveal" style="--delay: 100ms">
            <div
              class="screenshot-wrap"
              role="button"
              tabindex="0"
              aria-label="Open screenshot 2"
              data-index="1"
            >
              <img
                src={`${base}assets/screenshots/hide-and-seek-2.png`}
                alt="Hide and Seek — enemy chase state"
                loading="lazy"
              />
            </div>
            <p class="text-[#444444] text-xs font-mono mt-2">Enemy chase state — Cinemachine cut to close camera</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ─── RETROSPECTIVE ─────────────────────────────────────────────────── -->
    <section id="retrospective" class="py-20 border-t border-[#1F1F1F]/50">
      <div class="max-w-5xl mx-auto px-6">
        <h2 class="reveal text-2xl font-bold text-[#F0F0F0] mb-10">Retrospective</h2>

        <ul class="reveal space-y-4 max-w-3xl" style="--delay: 100ms">
          <li class="flex gap-3 text-[#888888] leading-relaxed">
            <span class="text-[#00FFC8] font-mono mt-0.5 shrink-0">—</span>
            <span>
              <!-- [YOUR NOTES HERE] -->
              <strong class="text-[#F0F0F0] font-medium">Detection cone should have been data-driven from the start.</strong>
              I hardcoded the sight angle and range, which meant every tweak required a code change. Exposing those as <code class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1 rounded">[SerializeField]</code> floats on the enemy prefab would have let me balance detection feel in the editor without recompiling.
            </span>
          </li>
          <li class="flex gap-3 text-[#888888] leading-relaxed">
            <span class="text-[#00FFC8] font-mono mt-0.5 shrink-0">—</span>
            <span>
              <!-- [YOUR NOTES HERE] -->
              <strong class="text-[#F0F0F0] font-medium">Patrol waypoints need a smarter selection strategy.</strong>
              The current system picks the next waypoint sequentially. Random or weighted selection based on last-seen player position would make the patrol feel less mechanical and harder to memorise.
            </span>
          </li>
          <li class="flex gap-3 text-[#888888] leading-relaxed">
            <span class="text-[#00FFC8] font-mono mt-0.5 shrink-0">—</span>
            <span>
              <!-- [YOUR NOTES HERE] -->
              <strong class="text-[#F0F0F0] font-medium">Should have added audio cues earlier in development.</strong>
              Detection feedback currently relies entirely on visual state changes. Adding sound — a heartbeat during Investigate, alert sting on Chase — would have shaped the tuning decisions from the beginning and made the feel tests much more informative.
            </span>
          </li>
        </ul>
      </div>
    </section>

    <!-- ─── WHAT'S NEXT ───────────────────────────────────────────────────── -->
    <section id="next" class="py-20 border-t border-[#1F1F1F]/50">
      <div class="max-w-5xl mx-auto px-6">
        <h2 class="reveal text-2xl font-bold text-[#F0F0F0] mb-10">What's Next</h2>

        <ul class="reveal space-y-3 max-w-3xl" style="--delay: 100ms">
          {[
            "SFX and music — alert stings, ambient tension tracks, footstep detection",
            "Multiple enemy types with distinct patrol behaviors and sight ranges",
            "Additional level layouts using the editor tilemap utilities",
            "Win / lose conditions with a proper HUD and score system",
            "Difficulty settings: wider cones and faster reaction times on hard",
          ].map((item) => (
            <li class="flex gap-3 text-[#888888]">
              <span class="text-violet-400 font-mono shrink-0">›</span>
              <span>{item}</span>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <!-- ─── FOOTER ────────────────────────────────────────────────────────── -->
    <footer class="border-t border-[#1F1F1F]/50 py-8">
      <div class="max-w-5xl mx-auto px-6 flex flex-col sm:flex-row items-center justify-between gap-4">
        <p class="text-[#888888] text-sm">© 2026 Marko Stankovic</p>

        <!-- Prev / Next project navigation -->
        <div class="flex items-center gap-6 text-sm">
          <span class="text-[#1F1F1F] font-mono">← prev</span>
          <span class="text-[#1F1F1F]">·</span>
          <a
            href="/projects/endless-runner"
            class="nav-link text-[#888888] hover:text-[#F0F0F0] transition-colors duration-150"
          >
            Endless Runner →
          </a>
        </div>

        <p class="text-[#444444] text-xs font-mono">Game Developer · Serbia</p>
      </div>
    </footer>

    <!-- ─── LIGHTBOX ──────────────────────────────────────────────────────── -->
    <div
      id="lightbox"
      role="dialog"
      aria-modal="true"
      aria-label="Screenshot viewer"
      class="fixed inset-0 z-[200] items-center justify-center"
    >
      <div id="lightbox-backdrop" class="absolute inset-0 bg-[#0D0D0D]/95"></div>

      <div id="lightbox-content" class="relative z-10 flex items-center gap-3 px-4">
        <button id="lightbox-prev" class="lb-btn" aria-label="Previous screenshot">
          <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/>
          </svg>
        </button>

        <img id="lightbox-img" src="" alt="Project screenshot" />

        <button id="lightbox-next" class="lb-btn" aria-label="Next screenshot">
          <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
          </svg>
        </button>
      </div>

      <button id="lightbox-close" class="lb-btn z-10" aria-label="Close lightbox">
        <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>

    <script>
      // ── Highlight.js init ────────────────────────────────────────────────
      // @ts-ignore
      if (typeof hljs !== 'undefined') hljs.highlightAll();
      document.addEventListener('DOMContentLoaded', () => {
        // @ts-ignore
        if (typeof hljs !== 'undefined') hljs.highlightAll();
      });

      // ── Scroll Reveal ─────────────────────────────────────────────────────
      const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      const revealEls = document.querySelectorAll('.reveal');

      if (!prefersReduced) {
        const obs = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add('visible');
                obs.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.1 }
        );
        revealEls.forEach((el) => obs.observe(el));
      } else {
        revealEls.forEach((el) => el.classList.add('visible'));
      }

      // ── Hamburger Nav ─────────────────────────────────────────────────────
      const menuBtn   = document.getElementById('menu-btn');
      const mobileNav = document.getElementById('mobile-nav');
      const iconMenu  = document.getElementById('icon-menu');
      const iconClose = document.getElementById('icon-close');

      menuBtn?.addEventListener('click', () => {
        const isOpen = mobileNav?.classList.toggle('open');
        menuBtn.setAttribute('aria-expanded', String(isOpen));
        iconMenu?.classList.toggle('hidden', !!isOpen);
        iconClose?.classList.toggle('hidden', !isOpen);
      });

      document.querySelectorAll('.mobile-nav-link').forEach((link) => {
        link.addEventListener('click', () => {
          mobileNav?.classList.remove('open');
          menuBtn?.setAttribute('aria-expanded', 'false');
          iconMenu?.classList.remove('hidden');
          iconClose?.classList.add('hidden');
        });
      });

      // ── Lightbox ──────────────────────────────────────────────────────────
      const lightbox   = document.getElementById('lightbox')!;
      const lbImg      = document.getElementById('lightbox-img') as HTMLImageElement;
      const lbPrev     = document.getElementById('lightbox-prev') as HTMLButtonElement;
      const lbNext     = document.getElementById('lightbox-next') as HTMLButtonElement;
      const lbClose    = document.getElementById('lightbox-close')!;
      const lbBackdrop = document.getElementById('lightbox-backdrop')!;

      const section = document.getElementById('screenshots')!;
      const lbScreenshots = (section?.dataset.screenshots ?? '')
        .split(',').map((s) => s.trim()).filter(Boolean);

      let lbIndex = 0;
      let lbPrevFocus: HTMLElement | null = null;

      function lbShow(index: number) {
        lbIndex = index;
        lbPrevFocus = document.activeElement as HTMLElement;
        lbUpdate();
        lightbox.style.display = 'flex';
        lightbox.getBoundingClientRect();
        lightbox.classList.add('lb-open');
        document.body.style.overflow = 'hidden';
        lbClose.focus();
      }

      function lbHide() {
        lightbox.classList.remove('lb-open');
        lightbox.addEventListener('transitionend', () => {
          lightbox.style.display = 'none';
          document.body.style.overflow = '';
          lbPrevFocus?.focus();
        }, { once: true });
      }

      function lbUpdate() {
        lbImg.src = lbScreenshots[lbIndex];
        lbImg.alt = `Screenshot ${lbIndex + 1} of ${lbScreenshots.length}`;
        lbPrev.disabled = lbIndex === 0;
        lbNext.disabled = lbIndex === lbScreenshots.length - 1;
      }

      document.querySelectorAll<HTMLElement>('.screenshot-wrap').forEach((wrap) => {
        const open = () => {
          const idx = parseInt(wrap.dataset.index ?? '0', 10);
          lbShow(idx);
        };
        wrap.addEventListener('click', open);
        wrap.addEventListener('keydown', (e) => {
          if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); open(); }
        });
      });

      lbClose.addEventListener('click', lbHide);
      lbBackdrop.addEventListener('click', lbHide);
      lbPrev.addEventListener('click', () => { if (lbIndex > 0) { lbIndex--; lbUpdate(); } });
      lbNext.addEventListener('click', () => { if (lbIndex < lbScreenshots.length - 1) { lbIndex++; lbUpdate(); } });

      lightbox.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') lbHide();
        else if (e.key === 'ArrowLeft'  && lbIndex > 0)                         { lbIndex--; lbUpdate(); }
        else if (e.key === 'ArrowRight' && lbIndex < lbScreenshots.length - 1)  { lbIndex++; lbUpdate(); }
      });
    </script>
  </body>
</html>
