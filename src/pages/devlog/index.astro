---
import { getCollection } from 'astro:content';
import "../../styles/global.css";
import BlogCard from '../../components/BlogCard.astro';

const allPosts = await getCollection('blog');
const posts = allPosts
  .filter(p => !p.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .map(post => {
    const words = (post.body ?? '').split(/\s+/).filter(Boolean).length;
    return {
      ...post,
      readingTime: Math.max(1, Math.ceil(words / 200)),
      slug: post.slug,
    };
  });

const allTags = [...new Set(posts.flatMap(p => p.data.tags))].sort();
const base = import.meta.env.BASE_URL;

const pageTitle = "Devlog — Marko Stankovic";
const pageDescription = "Architecture decisions, Unity patterns, and the trade-offs behind both.";
const canonicalURL = Astro.url.href;
const ogImageURL = new URL('/og-default.png', Astro.site).href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="google-site-verification" content="E7tgw1T5tN33WpBtQKaMPTkM6sIjSQEnNr33vyw-0ys" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <link rel="canonical" href={canonicalURL} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content={ogImageURL} />
    <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Geist:wght@300;400;500;600;700&family=JetBrains+Mono:ital,wght@0,400;0,500;0,600;0,700&display=swap"
      rel="stylesheet"
    />
  </head>

  <body class="font-sans antialiased">

    <!-- ─── NAV ──────────────────────────────────────────────────────────── -->
    <header class="fixed top-0 inset-x-0 z-50 border-b border-[#1F1F1F]/60 bg-[#0D0D0D]/80 backdrop-blur-md">
      <nav class="max-w-5xl mx-auto px-6 h-14 flex items-center justify-between">
        <a href="/" class="font-bold font-mono tracking-tight text-[#F0F0F0] text-lg">MS</a>

        <ul class="hidden sm:flex gap-6 text-sm text-[#888888]">
          <li><a href="/#skills"   class="nav-link hover:text-[#F0F0F0] transition-colors duration-150">Skills</a></li>
          <li><a href="/#projects" class="nav-link hover:text-[#F0F0F0] transition-colors duration-150">Projects</a></li>
          <li><a href="/devlog"    class="nav-link nav-active">Devlog</a></li>
          <li><a href="/#contact"  class="nav-link hover:text-[#F0F0F0] transition-colors duration-150">Contact</a></li>
        </ul>

        <button id="menu-btn" class="sm:hidden w-11 h-11 flex items-center justify-center text-[#888888] hover:text-[#F0F0F0] transition-colors duration-150" aria-label="Toggle menu" aria-expanded="false">
          <svg id="icon-menu" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
          </svg>
          <svg id="icon-close" class="w-5 h-5 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
      </nav>

      <div id="mobile-nav" aria-hidden="true">
        <div class="max-w-5xl mx-auto px-6 py-2 flex flex-col">
          <a href="/#skills"   tabindex="-1" class="mobile-nav-link py-3 text-sm text-[#888888] hover:text-[#F0F0F0] border-b border-[#1F1F1F] transition-colors duration-150 min-h-[44px] flex items-center">Skills</a>
          <a href="/#projects" tabindex="-1" class="mobile-nav-link py-3 text-sm text-[#888888] hover:text-[#F0F0F0] border-b border-[#1F1F1F] transition-colors duration-150 min-h-[44px] flex items-center">Projects</a>
          <a href="/devlog"    tabindex="-1" class="mobile-nav-link py-3 text-sm text-[#00FFC8] border-b border-[#1F1F1F] transition-colors duration-150 min-h-[44px] flex items-center">Devlog</a>
          <a href="/#contact"  tabindex="-1" class="mobile-nav-link py-3 text-sm text-[#888888] hover:text-[#F0F0F0] transition-colors duration-150 min-h-[44px] flex items-center">Contact</a>
        </div>
      </div>
    </header>

    <main>
    <!-- ─── HERO ──────────────────────────────────────────────────────────── -->
    <div class="relative pt-14">
      <div class="absolute inset-0 overflow-hidden pointer-events-none" aria-hidden="true">
        <div class="absolute top-1/3 right-1/4 w-[500px] h-[500px] bg-[#00FFC8]/4 rounded-full blur-3xl"></div>
      </div>
      <div class="relative max-w-5xl mx-auto px-6 py-20">
        <p class="hero-enter text-[#00FFC8] font-mono text-xs mb-4 tracking-wide" style="--delay: 0.05s">
          devlog
        </p>
        <h1 class="hero-enter font-mono font-bold text-[#F0F0F0] mb-3" style="font-size: clamp(2rem, 5vw, 3.5rem); line-height: 1.1; letter-spacing: -0.02em; --delay: 0.15s">
          // Devlog
        </h1>
        <p class="hero-enter text-[#888888] text-lg max-w-xl leading-relaxed" style="--delay: 0.3s">
          Architecture decisions, Unity patterns, and the trade-offs behind both.
        </p>
      </div>
    </div>

    <!-- ─── POSTS ─────────────────────────────────────────────────────────── -->
    <section class="py-16 border-t border-[#1F1F1F]/50">
      <div class="max-w-5xl mx-auto px-6">
        <h2 class="sr-only">Posts</h2>

        <!-- Filter bar -->
        <div id="filter-bar" class="flex gap-2 overflow-x-auto pb-2 mb-10 -mx-1 px-1">
          <button class="filter-btn active" data-tag="all">All</button>
          {allTags.map(tag => (
            <button class="filter-btn" data-tag={tag}>{tag}</button>
          ))}
        </div>

        <!-- Post list -->
        <div id="post-list" class="max-w-[740px] space-y-4">
          {posts.map((post, i) => (
            <div style={`--delay: ${i * 80}ms`}>
              <BlogCard
                title={post.data.title}
                date={post.data.date}
                excerpt={post.data.excerpt}
                tags={post.data.tags}
                slug={post.slug}
                readingTime={post.readingTime}
              />
            </div>
          ))}
        </div>

        {posts.length === 0 && (
          <p class="text-[#666666] font-mono text-sm">No posts yet. Check back soon.</p>
        )}
      </div>
    </section>

    </main>

    <!-- ─── FOOTER ────────────────────────────────────────────────────────── -->
    <footer class="border-t border-[#1F1F1F]/50 py-8">
      <div class="max-w-5xl mx-auto px-6 flex flex-col sm:flex-row items-center justify-between gap-3">
        <p class="text-[#888888] text-sm">© 2026 Marko Stankovic</p>
        <a href="/" class="nav-link text-[#666666] text-xs font-mono hover:text-[#888888] transition-colors duration-150">← Back to portfolio</a>
      </div>
    </footer>

    <script>
      // Scroll reveal
      const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      const revealEls = document.querySelectorAll('.reveal');
      if (!prefersReduced) {
        const obs = new IntersectionObserver((entries) => {
          entries.forEach((e) => { if (e.isIntersecting) { e.target.classList.add('visible'); obs.unobserve(e.target); } });
        }, { threshold: 0.1 });
        revealEls.forEach((el) => obs.observe(el));
      } else {
        revealEls.forEach((el) => el.classList.add('visible'));
      }

      // Mobile menu
      const menuBtn = document.getElementById('menu-btn');
      const mobileNav = document.getElementById('mobile-nav');
      const iconMenu = document.getElementById('icon-menu');
      const iconClose = document.getElementById('icon-close');
      const mobileNavLinks = document.querySelectorAll<HTMLElement>('.mobile-nav-link');

      function closeMobileNav() {
        mobileNav?.classList.remove('open');
        mobileNav?.setAttribute('aria-hidden', 'true');
        menuBtn?.setAttribute('aria-expanded', 'false');
        iconMenu?.classList.remove('hidden');
        iconClose?.classList.add('hidden');
        mobileNavLinks.forEach((link) => link.setAttribute('tabindex', '-1'));
      }

      menuBtn?.addEventListener('click', () => {
        const isOpen = mobileNav?.classList.toggle('open');
        menuBtn.setAttribute('aria-expanded', String(isOpen));
        iconMenu?.classList.toggle('hidden', !!isOpen);
        iconClose?.classList.toggle('hidden', !isOpen);
        if (isOpen) {
          mobileNav?.removeAttribute('aria-hidden');
          mobileNavLinks.forEach((link) => link.removeAttribute('tabindex'));
        } else {
          mobileNav?.setAttribute('aria-hidden', 'true');
          mobileNavLinks.forEach((link) => link.setAttribute('tabindex', '-1'));
        }
      });
      mobileNavLinks.forEach((link) => {
        link.addEventListener('click', closeMobileNav);
      });

      // Tag filter
      const filterBtns = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
      const cards = document.querySelectorAll<HTMLElement>('.blog-card');

      filterBtns.forEach(btn => {
        btn.addEventListener('click', () => {
          filterBtns.forEach(b => b.classList.remove('active'));
          btn.classList.add('active');
          const tag = btn.dataset.tag ?? 'all';

          cards.forEach(card => {
            if (tag === 'all') {
              card.classList.remove('filtered-out');
            } else {
              const cardTags = (card.dataset.tags ?? '').split(',');
              card.classList.toggle('filtered-out', !cardTags.includes(tag));
            }
          });
        });
      });
    </script>
  </body>
</html>
