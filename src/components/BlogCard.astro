---
interface Props {
  title: string;
  date: Date;
  excerpt: string;
  tags: string[];
  slug: string;
  readingTime: number;
}

const { title, date, excerpt, tags, slug, readingTime } = Astro.props;
const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<article class="reveal blog-card" data-tags={tags.join(',')}>
  <div class="border border-[#1F1F1F] bg-[#141414] rounded-xl p-6 hover:border-[#888888] transition-colors duration-200">
    <div class="flex flex-wrap items-center gap-3 mb-3">
      <time class="text-xs font-mono text-[#444444]">{formattedDate}</time>
      <span class="text-[#1F1F1F]">·</span>
      <span class="text-xs font-mono text-[#444444]">{readingTime} min read</span>
    </div>

    <h3 class="font-mono font-semibold text-[#F0F0F0] text-lg mb-2 leading-snug">
      <a href={`/devlog/${slug}`} class="hover:text-[#00FFC8] transition-colors duration-150">{title}</a>
    </h3>

    <p class="text-[#888888] text-sm leading-relaxed mb-4">{excerpt}</p>

    <div class="flex items-center justify-between">
      <div class="flex flex-wrap gap-1.5">
        {tags.map(tag => (
          <span class="text-xs font-mono bg-[#1F1F1F] text-[#888888] px-2 py-0.5 rounded-full border border-[#1F1F1F]">
            {tag}
          </span>
        ))}
      </div>
      <a
        href={`/devlog/${slug}`}
        class="github-link inline-flex items-center gap-1 text-sm text-[#00FFC8] hover:text-[#00FFD0] transition-colors duration-150 shrink-0 ml-4"
        aria-label={`Read ${title}`}
      >
        Read
        <svg class="arrow w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
        </svg>
      </a>
    </div>
  </div>
</article>
